# Server
PORT=8000
NODE_ENV=development

# Session - use a strong random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-random-secret

# Set to true when using HTTPS (e.g. behind nginx + Let's Encrypt)
SESSION_SECURE=false

# Public site URL, no trailing slash — canonical URLs, sitemap.xml, JSON-LD, and client notification links
PUBLIC_BASE_URL=https://www.yourdomain.com
# Alias also accepted if you already use it elsewhere:
# PUBLIC_SITE_URL=https://www.yourdomain.com

# Optional — used in notification email copy (defaults to Designer's Vision)
EMAIL_BRAND_NAME=Designer's Vision
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=designersvisionstudio@gmail.com
EMAIL_PASS=umsx jsrj nuoy dybe
EMAIL_FROM="Designer's Vision info@designersvision.studio>"