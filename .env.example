# Server
PORT=8000
NODE_ENV=development

# Session - use a strong random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-random-secret

# Set to true when using HTTPS (e.g. behind nginx + Let's Encrypt)
SESSION_SECURE=false

# Email (portal notifications, meeting invites text) — see server env docs for SMTP variables
# EMAIL_HOST= EMAIL_PORT=465 EMAIL_USER= EMAIL_PASS=

# Optional: automatic Google Calendar events + Meet links require Google Calendar API
# (OAuth or Workspace service account + domain-wide delegation). Not required for the
# built-in “Add to Google Calendar” + paste Meet link flow in the portal Meetings tab.
