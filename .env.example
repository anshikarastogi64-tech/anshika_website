# Server
PORT=8000
NODE_ENV=development

# Session - use a strong random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-random-secret

# Set to true when using HTTPS (e.g. behind nginx + Let's Encrypt)
SESSION_SECURE=false

# Public site URL, no trailing slash — used for links in client notification emails
PUBLIC_BASE_URL=https://www.yourdomain.com

