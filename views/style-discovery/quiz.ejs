<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <%- include('../partials/seo-minimal') %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
  <link href="/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    :root { --gold: #d4af37; --bg: #0a0a0a; --glass: rgba(255, 255, 255, 0.05); }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: #fff; min-height: 100vh; padding: 20px; }
    .progress-track { height: 4px; background: #222; position: fixed; top: 0; left: 0; right: 0; z-index: 1; }
    .progress-fill { height: 100%; background: var(--gold); transition: width 0.4s ease; width: <%= (step / totalSteps) * 100 %>%; }
    .quiz-wrapper { max-width: 800px; margin: 0 auto; padding-top: 40px; }
    .quiz-wrapper h1 { font-family: 'Playfair Display', serif; color: var(--gold); }
    .option-card { border-radius: 12px; overflow: hidden; border: 1px solid var(--glass); transition: all 0.3s; cursor: pointer; }
    .option-card:hover { border-color: var(--gold); box-shadow: 0 10px 30px rgba(212,175,55,0.2); transform: translateY(-4px); }
    .image-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .btn-gold { background: var(--gold); color: #0a0a0a; border: none; font-weight: 600; }
  </style>
</head>
<body>
  <div class="progress-track"><div class="progress-fill"></div></div>
  <div class="quiz-wrapper">
    <h1 class="mb-4">Step <%= step %> of <%= totalSteps %></h1>
    <p class="text-muted mb-4">Choose the option that best reflects your style. (Demo: select any to continue.)</p>
    <div class="image-grid">
      <a href="/style-discovery/quiz?step=<%= step >= totalSteps ? totalSteps : step + 1 %>" class="option-card text-decoration-none text-light">
        <div style="height:180px; background: linear-gradient(135deg, #2a2a2a, #1a1a1a); display:flex; align-items:center; justify-content:center;">Option A</div>
        <div class="p-3">Natural & Light</div>
      </a>
      <a href="/style-discovery/quiz?step=<%= step >= totalSteps ? totalSteps : step + 1 %>" class="option-card text-decoration-none text-light">
        <div style="height:180px; background: linear-gradient(135deg, #3a2a1a, #2a1a0a); display:flex; align-items:center; justify-content:center;">Option B</div>
        <div class="p-3">Warm & Textured</div>
      </a>
      <a href="/style-discovery/quiz?step=<%= step >= totalSteps ? totalSteps : step + 1 %>" class="option-card text-decoration-none text-light">
        <div style="height:180px; background: linear-gradient(135deg, #1a1a2a, #0a0a1a); display:flex; align-items:center; justify-content:center;">Option C</div>
        <div class="p-3">Moody & Rich</div>
      </a>
      <a href="/style-discovery/quiz?step=<%= step >= totalSteps ? totalSteps : step + 1 %>" class="option-card text-decoration-none text-light">
        <div style="height:180px; background: linear-gradient(135deg, #2a2a2a, #0a0a0a); display:flex; align-items:center; justify-content:center;">Option D</div>
        <div class="p-3">Minimal & Clean</div>
      </a>
    </div>
    <% if (step >= totalSteps) { %>
    <div class="mt-4"><a href="/style-discovery/result" class="btn btn-gold btn-lg">See my result</a></div>
    <% } %>
  </div>
</body>
</html>
