<section class="testimonial-detail">
  <div class="container py-5" data-aos="fade-up">
    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/testimonials">Testimonials</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= (testimonial.name || 'Testimonial').replace(/"/g, '&quot;') %></li>
      </ol>
    </nav>

    <div class="row mb-5 align-items-start">
      <div class="col-lg-4 col-md-5 mb-4 mb-md-0 text-center">
        <% if (testimonial.image_path) { %>
        <img loading="lazy" src="/<%= testimonial.image_path %>" class="img-fluid rounded-circle shadow-sm" alt="<%= (testimonial.name || '').replace(/"/g, '&quot;') %>" style="max-width: 220px; width: 100%; aspect-ratio: 1; object-fit: cover;">
        <% } else { %>
        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 220px; height: 220px;">
          <i class="bx bxs-user" style="font-size: 100px; color: #999;"></i>
        </div>
        <% } %>
      </div>
      <div class="col-lg-8 col-md-7">
        <h2 class="mb-2"><%= testimonial.name || '' %></h2>
        <% if (testimonial.role && testimonial.role.trim()) { %>
        <p class="text-muted mb-3"><%= testimonial.role %></p>
        <% } %>
        <% if (testimonial.rating && testimonial.rating > 0) { %>
        <div class="mb-3">
          <% for (var i = 1; i <= 5; i++) { %>
          <i class="bx <%= i <= testimonial.rating ? 'bxs-star' : 'bx-star' %>" style="color: #ffc107; font-size: 1.5rem;"></i>
          <% } %>
          <span class="ms-2 text-muted"><%= testimonial.rating %> / 5</span>
        </div>
        <% } %>
        <div class="testimonial-message mb-4">
          <p class="lead">
            <i class="bx bxs-quote-alt-left quote-icon-left" style="color: #c8efea; font-size: 28px;"></i>
            <%= testimonial.message || '' %>
            <i class="bx bxs-quote-alt-right quote-icon-right" style="color: #c8efea; font-size: 28px;"></i>
          </p>
        </div>
      </div>
    </div>

    <% const media = (typeof testimonialMedia !== 'undefined' && Array.isArray(testimonialMedia)) ? testimonialMedia : []; %>
    <% if (media.length > 0) { %>
    <div class="row mb-5">
      <div class="col-12">
        <h4 class="mb-4">Photos & Videos</h4>
        <div class="testimonial-gallery-grid">
          <% media.forEach(function(m) { %>
          <div class="testimonial-gallery-item" data-type="<%= m.type %>">
            <% if (m.type === 'image') { %>
            <a href="/<%= m.path %>" class="portfolio-lightbox testimonial-gallery-img" data-gallery="testimonial-gallery">
              <img loading="lazy" src="/<%= m.path %>" alt="">
            </a>
            <% } else if (m.type === 'video') { %>
            <div class="testimonial-gallery-video">
              <iframe src="<%= m.path %>" allowfullscreen></iframe>
            </div>
            <% } %>
          </div>
          <% }); %>
        </div>
        <style>
        .testimonial-gallery-grid {
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
          gap: 12px;
        }
        .testimonial-gallery-item { overflow: hidden; border-radius: 8px; background: #f8f9fa; }
        .testimonial-gallery-img {
          display: block; aspect-ratio: 4/3; overflow: hidden;
        }
        .testimonial-gallery-img img {
          width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;
        }
        .testimonial-gallery-img:hover img { transform: scale(1.05); }
        .testimonial-gallery-video {
          aspect-ratio: 16/9; overflow: hidden; position: relative;
        }
        .testimonial-gallery-video iframe {
          position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;
        }
        </style>
      </div>
    </div>
    <% } %>

    <div class="mt-4">
      <a href="/testimonials" class="btn btn-outline-primary">&larr; Back to Testimonials</a>
    </div>
  </div>
</section>
