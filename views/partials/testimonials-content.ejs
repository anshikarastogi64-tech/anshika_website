<section id="testimonials" class="testimonials">
  <style>.testimonial-card-link:hover .testimonial-item { box-shadow: 0 0.5rem 1rem rgba(0,0,0,.1); } .testimonial-card-link .testimonial-item { transition: box-shadow 0.2s; }</style>
  <div class="container py-5" data-aos="fade-up">
    <div class="section-title">
      <h2>Testimonials</h2>
      <p>What clients say about our work</p>
    </div>

    <div class="row g-4">
      <% const list = (typeof testimonials !== 'undefined' && Array.isArray(testimonials)) ? testimonials : []; %>
      <% const mediaMap = typeof mediaByTestimonial !== 'undefined' ? mediaByTestimonial : {}; %>
      <% list.forEach(function(t) { %>
      <div class="col-lg-4 col-md-6">
        <a href="/testimonials/<%= t.id %>" class="text-decoration-none text-dark d-block testimonial-card-link">
        <div class="testimonial-item">
          <% if (t.image_path) { %>
          <img loading="lazy" src="/<%= t.image_path %>" class="testimonial-img" alt="">
          <% } else { %>
          <div class="testimonial-img-placeholder rounded-circle mx-auto d-flex align-items-center justify-content-center bg-light" style="width:120px; height:120px;">
            <i class="bx bxs-user" style="font-size: 48px; color: #999;"></i>
          </div>
          <% } %>
          <% if (t.rating && t.rating > 0) { %>
          <div class="mb-2">
            <% for (var i = 1; i <= 5; i++) { %>
            <i class="bx <%= i <= t.rating ? 'bxs-star' : 'bx-star' %>" style="color: #ffc107;"></i>
            <% } %>
          </div>
          <% } %>
          <h3><%= t.name || '' %></h3>
          <h4><%= t.role || '' %></h4>
          <p>
            <i class="bx bxs-quote-alt-left quote-icon-left"></i>
            <%= t.message || '' %>
            <i class="bx bxs-quote-alt-right quote-icon-right"></i>
          </p>
        </div>
        </a>
      </div>
      <% }); %>
    </div>

    <% if (list.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <p>No testimonials yet. Check back soon!</p>
    </div>
    <% } %>
  </div>
</section>
