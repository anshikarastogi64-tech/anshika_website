<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <% var _seo = typeof seo !== 'undefined' && seo ? seo : {}; %>
  <meta name="robots" content="<%= _seo.robots || 'noindex, nofollow' %>" />
  <meta name="description" content="<%= _seo.description || 'Interior design client portal — project updates and documents.' %>" />
  <% if (_seo.canonical) { %><link rel="canonical" href="<%= _seo.canonical %>" /><% } %>
  <title><%= typeof title !== 'undefined' ? title : 'Portal' %> – Luxury Interior | Designer's Vision</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />
  <link href="/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
  <style>
    :root {
      --charcoal: #121212;
      --gold: #D4AF37;
      --gold-hover: #c5a030;
      --bone: #F8F8F8;
      --glass: rgba(255, 255, 255, 0.05);
      --border: rgba(212, 175, 55, 0.3);
    }
    body { font-family: 'Inter', sans-serif; background: var(--charcoal); color: var(--bone); min-height: 100vh; }
    .portal-nav { background: var(--charcoal); border-bottom: 1px solid var(--border); }
    .portal-nav .navbar-brand { font-family: 'Playfair Display', serif; color: var(--gold) !important; }
    .portal-nav .nav-link { color: rgba(248,248,248,0.9) !important; }
    .portal-nav .nav-link:hover { color: var(--gold) !important; }
    .portal-nav .navbar-text { color: rgba(248, 248, 248, 0.9) !important; }
    .portal-nav .navbar-text strong { color: var(--bone); font-weight: 600; }
    .btn-gold { background: var(--gold); color: var(--charcoal); border: none; font-weight: 600; }
    .btn-gold:hover { background: var(--gold-hover); color: var(--charcoal); }
    .btn-outline-gold { border: 1px solid var(--gold); color: var(--gold); background: transparent; }
    .btn-outline-gold:hover { background: var(--gold); color: var(--charcoal); }
    .card-portal { background: var(--glass); border: 1px solid var(--border); border-radius: 8px; }
    .card-portal .card-header { border-bottom: 1px solid var(--border); font-family: 'Playfair Display', serif; color: var(--gold); }
    /* Card body and all body text: visible on dark background (admin, designer, client) */
    .card-portal .card-body { color: #e8e8e8; }
    .card-portal .card-body p, .card-portal .card-body h4, .card-portal .card-body h5, .card-portal .card-body h6,
    .card-portal .card-body li, .card-portal .card-body span { color: #e8e8e8; }
    /* Muted/secondary text: use light grey so it's readable on dark background */
    .text-muted, .text-secondary, .card-portal .text-muted, .card-portal .text-secondary,
    .card-portal small.text-muted { color: #d4d4d4 !important; }
    h1, h2, h3, .serif { font-family: 'Playfair Display', serif; }
    .mirror-banner { background: linear-gradient(90deg, var(--gold), #b8962e); color: var(--charcoal); padding: 8px 16px; text-align: center; font-weight: 600; }
    .portal-tabs.nav-tabs { border-bottom-color: var(--border); }
    .portal-tabs .nav-link { color: rgba(248,248,248,0.8); border-color: transparent; background: transparent; }
    .portal-tabs .nav-link:hover { color: var(--gold); border-color: transparent; }
    .portal-tabs .nav-link.active { color: var(--gold); background: transparent; border-color: var(--border) var(--border) transparent; font-weight: 600; }
    .portal-nav .navbar-brand img { height: 52px; width: auto; display: block; }
    /* Portal layout responsiveness */
    @media (max-width: 991.98px) {
      .portal-nav .nav-link { padding-left: 0.25rem; padding-right: 0.25rem; }
      .portal-nav .navbar-brand img { height: 40px; }
      .container { padding-left: 1rem; padding-right: 1rem; }
      .card-portal { margin-bottom: 1rem; }
      .portal-tabs.nav-tabs {
        flex-wrap: wrap;
        row-gap: 0.25rem;
      }
      .portal-tabs .nav-link {
        white-space: nowrap;
        padding: 0.4rem 0.6rem;
        font-size: 0.85rem;
      }
      /* Make wide tables scrollable on small screens */
      table.table {
        display: block;
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        white-space: nowrap;
      }
    }
    .portal-payment-finance-toggle.collapsed .portal-payment-finance-chevron { transform: rotate(-90deg); }
    .portal-payment-finance-toggle:not(.collapsed) .portal-payment-finance-chevron { transform: rotate(0deg); }
    .portal-payment-finance-chevron { transition: transform 0.2s ease; display: inline-block; }
    .portal-lifecycle-toggle.collapsed .portal-lifecycle-chevron { transform: rotate(-90deg); }
    .portal-lifecycle-toggle:not(.collapsed) .portal-lifecycle-chevron { transform: rotate(0deg); }
    .portal-lifecycle-chevron { transition: transform 0.2s ease; display: inline-block; }
  </style>
</head>
<body>
  <% var dashboardPath = portalUser && portalUser.role === 'ADMIN'
        ? '/portal/admin'
        : (portalUser && portalUser.role === 'DESIGNER'
          ? '/portal/designer'
          : '/portal/client'); %>
  <% if (typeof mirrorBanner !== 'undefined' && mirrorBanner) { %>
  <div class="mirror-banner">View as client (read-only)</div>
  <% } %>
  <nav class="navbar navbar-expand-lg portal-nav">
    <div class="container-fluid">
      <a class="navbar-brand d-flex align-items-center" href="<%= dashboardPath %>">
        <img src="/assets/img/portal/logo-dv.png" alt="Designer's Vision" />
      </a>
      <button class="navbar-toggler text-light border-0" type="button" data-bs-toggle="collapse" data-bs-target="#portalNav" aria-controls="portalNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="bi bi-list" style="font-size:1.5rem;"></span>
      </button>
      <div class="collapse navbar-collapse" id="portalNav">
        <ul class="navbar-nav me-auto">
          <% if (portalUser.role === 'ADMIN') { %>
          <li class="nav-item"><a class="nav-link" href="/portal/admin">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/portal/admin/users">Users</a></li>
          <li class="nav-item"><a class="nav-link" href="/portal/admin/leads">Leads</a></li>
          <li class="nav-item"><a class="nav-link" href="/portal/admin/projects">Projects</a></li>
          <li class="nav-item"><a class="nav-link" href="/portal/admin/notification-settings">Alert settings</a></li>
          <% } else if (portalUser.role === 'DESIGNER') { %>
          <li class="nav-item"><a class="nav-link" href="/portal/designer">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/portal/designer/leads">Leads</a></li>
          <li class="nav-item"><a class="nav-link" href="/portal/designer/projects">Projects</a></li>
          <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/portal/client">Dashboard</a></li>
          <% } %>
        </ul>
        <a class="nav-link position-relative me-2" href="/portal/notifications" title="Notifications">
          <i class="bi bi-bell fs-5"></i>
          <% var _unc = typeof portalUnreadCount !== 'undefined' ? portalUnreadCount : 0; if (_unc > 0) { %>
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark" style="font-size:0.65rem"><%= _unc > 99 ? '99+' : _unc %></span>
          <% } %>
        </a>
        <a class="nav-link me-2" href="/">Main website</a>
        <span class="navbar-text me-3">Signed in as <strong><%= portalUser.name || portalUser.email %></strong></span>
        <form method="post" action="/portal/logout" class="d-inline">
          <button type="submit" class="btn btn-outline-gold btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>
  <div class="container py-4">
    <%- body %>
  </div>
  <%- include('partials/portal_pdf_modal') %>
  <script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
  // Activate correct tab from URL hash or one-time session flag (e.g. #tab-vault, #tab-finance, #tab-daily)
  document.addEventListener('DOMContentLoaded', function() {
    try {
      if (!window.bootstrap) return;
      var hash = window.location.hash || '';
      var targetHash = '';
      if (hash && hash.indexOf('#tab-') === 0) {
        targetHash = hash;
      } else if (window.sessionStorage) {
        var stored = window.sessionStorage.getItem('portalActiveTab');
        if (stored && stored.indexOf('tab-') === 0) {
          targetHash = '#' + stored;
          window.sessionStorage.removeItem('portalActiveTab');
        }
      }
      if (targetHash) {
        var tabTrigger = document.querySelector('[data-bs-target=\"' + targetHash + '\"]');
        if (tabTrigger) {
          var tab = window.bootstrap.Tab.getOrCreateInstance(tabTrigger);
          tab.show();
        }
      }      
    } catch (e) {}
  });

  document.addEventListener('DOMContentLoaded', function() {
    var modalEl = document.getElementById('portalPdfViewerModal');
    var frame = document.getElementById('portalPdfViewerFrame');
    var titleEl = document.getElementById('portalPdfViewerTitle');
    var newTabEl = document.getElementById('portalPdfViewerNewTab');
    if (!modalEl || !frame || !window.bootstrap) return;

    window.portalAssetLooksLikePdf = function (url, fileName, mediaType) {
      var u = (url || '').toString().split('#')[0].split('?')[0].toLowerCase();
      var f = (fileName || '').toString().toLowerCase();
      if (u.endsWith('.pdf') || f.endsWith('.pdf')) return true;
      if (String(mediaType || '').toUpperCase() === 'DOCUMENT' && (f.indexOf('.pdf') !== -1 || u.indexOf('.pdf') !== -1)) return true;
      return false;
    };

    window.openPortalPdfViewer = function (url, title) {
      if (!url) return;
      title = title || 'PDF document';
      frame.src = 'about:blank';
      requestAnimationFrame(function () {
        frame.src = url;
      });
      if (titleEl) titleEl.textContent = title;
      if (newTabEl) newTabEl.href = url;
      var inst = window.bootstrap.Modal.getOrCreateInstance(modalEl);
      inst.show();
    };

    modalEl.addEventListener('hidden.bs.modal', function () {
      frame.src = 'about:blank';
    });

    document.addEventListener('click', function (e) {
      var a = e.target.closest('a[data-portal-pdf]');
      if (!a) return;
      var href = a.getAttribute('href');
      if (!href || href === '#' || href.indexOf('javascript:') === 0) return;
      e.preventDefault();
      window.openPortalPdfViewer(href, a.getAttribute('data-portal-pdf-name') || '');
    });
  });

  // Global helper to switch to Daily Updates tab and scroll to the Daily Update card.
  window.switchToDailyUpdates = function() {
    try {
      var dailyBtn = document.getElementById('tab-daily-btn');
      if (dailyBtn && window.bootstrap) {
        var t = window.bootstrap.Tab.getOrCreateInstance(dailyBtn);
        t.show();
      }
      // Scroll to the Daily Update card
      setTimeout(function() {
        var card = document.getElementById('dailyUpdateCard');
        if (card) {
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }, 150);
    } catch (e) {}
  };
  </script>
</body>
</html>
