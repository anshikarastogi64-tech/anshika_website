<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Portal Login – Luxury Interior</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />
  <link href="/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    :root { --charcoal: #121212; --gold: #D4AF37; --bone: #F8F8F8; --border: rgba(212, 175, 55, 0.3); }
    body { font-family: 'Inter', sans-serif; background: var(--charcoal); color: var(--bone); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-card { background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 12px; max-width: 400px; }
    .login-card h1 { font-family: 'Playfair Display', serif; color: var(--gold); }
    .btn-gold { background: var(--gold); color: var(--charcoal); border: none; font-weight: 600; }
    .form-control { background: rgba(0,0,0,0.3); border: 1px solid var(--border); color: var(--bone); }
    .form-control:focus { background: rgba(0,0,0,0.4); border-color: var(--gold); color: var(--bone); }
  </style>
</head>
<body>
  <div class="login-card p-4 w-100">
    <h1 class="mb-4">Portal Login</h1>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form method="post" action="/portal/login">
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" required />
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required />
      </div>
      <button type="submit" class="btn btn-gold w-100">Sign in</button>
    </form>
  </div>
</body>
</html>
