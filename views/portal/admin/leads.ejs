<h1 class="serif text-warning mb-4">Leads</h1>
<p><a href="/portal/admin/leads/new" class="btn btn-gold">Add Lead</a></p>
<div class="table-responsive">
  <table class="table table-dark table-striped table-bordered border-secondary">
    <thead><tr><th>Name</th><th>Phone</th><th>Email</th><th>Status</th><th>Referred by</th><th>Designer</th><th>Actions</th></tr></thead>
    <tbody>
      <% leads.forEach(function(l) { %>
      <tr>
        <td><%= l.name %></td>
        <td><%= l.phone_number %></td>
        <td><%= l.email || '–' %></td>
        <td><%= l.status %></td>
        <td><%= l.referrer_name || '–' %></td>
        <td><%= l.designer_name || '–' %></td>
        <td><a href="/portal/admin/leads/<%= l.id %>" class="btn btn-outline-gold btn-sm">View</a></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
