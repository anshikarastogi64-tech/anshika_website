<%
  var pid = project && project.id ? String(project.id) : '0';
  var suffix = typeof lifecycleCollapseSuffix !== 'undefined' ? String(lifecycleCollapseSuffix) : 'x';
  var panelId = 'portal-lifecycle-' + suffix + '-' + pid;
  var action = typeof formAction !== 'undefined' ? formAction : '';
  var lh =
    typeof lifecycleHeadline === 'function'
      ? lifecycleHeadline(project)
      : typeof LIFECYCLE_STAGES !== 'undefined' && LIFECYCLE_STAGES[project.current_stage]
        ? LIFECYCLE_STAGES[project.current_stage].name
        : project.current_stage;
%>
<div class="card card-portal mb-4">
  <div class="card-header p-0 border-secondary">
    <button
      type="button"
      class="btn btn-link text-start w-100 text-decoration-none text-light py-3 px-3 d-flex flex-wrap justify-content-between align-items-center gap-2 collapsed portal-lifecycle-toggle"
      data-bs-toggle="collapse"
      data-bs-target="#<%= panelId %>"
      aria-expanded="false"
      aria-controls="<%= panelId %>"
    >
      <span class="mb-0 text-wrap">
        <span class="serif text-warning">Lifecycle progress</span>
        <span class="text-light mx-2">·</span>
        <span class="small text-muted"><%= lh %></span>
      </span>
      <span class="d-flex align-items-center gap-2 small text-muted flex-shrink-0">
        <span class="d-none d-sm-inline">Update</span>
        <i class="bi bi-chevron-down portal-lifecycle-chevron" aria-hidden="true"></i>
      </span>
    </button>
  </div>
  <div id="<%= panelId %>" class="collapse">
    <div class="card-body border-top border-secondary">
      <p class="small text-muted mb-3">Mark stages as completed or in progress. Multiple stages can be in progress at once. Green, yellow, and grey match what the client sees.</p>
      <%- include('./project_stage_picker', { project, formAction: action }) %>
    </div>
  </div>
</div>
