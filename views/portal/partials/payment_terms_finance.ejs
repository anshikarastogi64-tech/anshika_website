<%
  var pt = typeof paymentTerms !== 'undefined' && paymentTerms ? paymentTerms : { intro: '', items: [] };
  var qb = typeof quotationBaseForTerms !== 'undefined' ? Number(quotationBaseForTerms) : 0;
  var ct = typeof contractTotal !== 'undefined' ? Number(contractTotal) : 0;
  var varAmt = Math.max(0, ct - qb);
  var edit = typeof paymentTermsEditMode !== 'undefined' && paymentTermsEditMode;
  var pid = typeof project !== 'undefined' && project && project.id ? project.id : '';
  var embed = typeof paymentTermsEmbed !== 'undefined' && paymentTermsEmbed;
  var sectionSpaced = typeof paymentTermsSectionSpaced !== 'undefined' && paymentTermsSectionSpaced;
%>
<% if (!embed) { %>
<div class="card card-portal mb-4 border-secondary">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
    <span class="serif text-warning mb-0">Payment terms &amp; schedule</span>
    <% if (edit) { %><span class="small text-muted">Visible to the client on the Finance tab</span><% } %>
  </div>
  <div class="card-body">
<% } else { %>
<section class="payment-terms-finance-embed mb-0<%= sectionSpaced ? ' pt-4' : '' %>">
  <h6 class="serif text-warning mb-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
    <span>Payment terms &amp; schedule</span>
    <% if (edit) { %><span class="small text-muted fw-normal">Visible to the client on the Finance tab</span><% } %>
  </h6>
<% } %>
    <% if (edit) { %>
    <p class="small text-muted mb-3">Every milestone <strong>%</strong> applies to the <strong>contract total</strong> (approved quotation plus approved extra costs). When the filled rows add up to <strong>100%</strong>, the rupee previews below add up to that contract total.</p>
    <p class="small text-warning mb-2"><strong>Required:</strong> every filled row’s percentages must add up to exactly <strong>100%</strong>. You can have up to <strong>10</strong> milestones — use <strong>Add below</strong> on a row, or <strong>Remove</strong> to delete a row. Reorder with the arrows.</p>
    <% if (pt.items && pt.items.length > 10) { %>
    <p class="small text-danger mb-2">This project has more than 10 stored milestones; only the first 10 are editable below. Saving will drop any extra rows — contact a developer if you need to preserve them.</p>
    <% } %>
    <div class="small mb-3 p-2 rounded border border-secondary border-opacity-25 bg-dark bg-opacity-25">
      <div class="text-muted mb-1">Contract breakdown (same as Finance summary)</div>
      <ul class="mb-0 ps-3">
        <li>Approved quotation base: <strong class="text-warning">₹<%= qb.toLocaleString('en-IN') %></strong></li>
        <li>Approved extra costs (variations): <strong class="text-warning">₹<%= varAmt.toLocaleString('en-IN') %></strong></li>
        <li class="fw-semibold text-light">Contract total (100% of schedule): <strong class="text-warning">₹<%= ct.toLocaleString('en-IN') %></strong></li>
      </ul>
    </div>
    <% var rowMax = Math.min(10, Math.max((pt.items && pt.items.length) || 0, 1)); %>
    <form method="post" action="/portal/admin/projects/<%= pid %>/payment-terms" class="mb-3" id="portal-payment-terms-form" data-contract-total="<%= ct %>" data-pt-max-rows="10">
      <label class="form-label small text-muted">Introduction or conditions (optional)</label>
      <textarea name="payment_terms_intro" class="form-control form-control-sm bg-dark text-light border-secondary mb-3" rows="3" placeholder="e.g. All amounts exclude GST unless noted. Milestones are due on the dates agreed in writing."><%= pt.intro || '' %></textarea>
      <div class="table-responsive mb-3">
        <table class="table table-dark table-sm table-bordered border-secondary align-middle">
          <thead>
            <tr class="text-muted small">
              <th style="width:2rem">#</th>
              <th>Milestone / description</th>
              <th style="width:6rem">% of contract</th>
              <th style="width:11rem">Due date</th>
              <th style="width:9rem" class="text-end">Preview (₹)</th>
              <th style="width:7.5rem" class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody id="portal-payment-terms-tbody">
            <% for (var i = 0; i < rowMax; i++) {
              var row = (pt.items && pt.items[i]) ? pt.items[i] : {};
              var preview = (Number(row.percent) || 0) * ct / 100;
            %>
            <tr class="js-pt-row">
              <td class="text-muted small js-pt-row-num"><%= i + 1 %></td>
              <td>
                <input type="hidden" name="pt_basis_<%= i %>" value="TOTAL" class="js-pt-basis" />
                <input type="text" name="pt_label_<%= i %>" class="form-control form-control-sm bg-dark text-light border-secondary js-pt-label" value="<%= row.label != null ? row.label : '' %>" placeholder="Milestone name" autocomplete="off" />
              </td>
              <td><input type="number" name="pt_pct_<%= i %>" step="0.01" min="0" max="100" class="form-control form-control-sm bg-dark text-light border-secondary js-pt-pct" value="<%= row.percent != null && row.percent !== '' ? row.percent : '' %>" placeholder="%" /></td>
              <td><input type="date" name="pt_due_<%= i %>" class="form-control form-control-sm bg-dark text-light border-secondary js-pt-due" value="<%= row.dueDate ? row.dueDate : '' %>" title="Optional target date for this milestone" /></td>
              <td class="text-end small pt-admin-preview text-muted" data-pt-preview-row="<%= i %>"><%= (row.label && row.percent != null && row.percent !== '') ? ('₹' + Math.round(preview).toLocaleString('en-IN')) : '—' %></td>
              <td class="text-nowrap text-center">
                <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 me-0 js-pt-add-after" title="Add row below"><i class="bi bi-plus-lg" aria-hidden="true"></i></button>
                <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 js-pt-move-up" title="Move up"><i class="bi bi-arrow-up" aria-hidden="true"></i></button>
                <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 js-pt-move-down" title="Move down"><i class="bi bi-arrow-down" aria-hidden="true"></i></button>
                <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1 js-pt-remove" title="Remove row"><i class="bi bi-trash" aria-hidden="true"></i></button>
              </td>
            </tr>
            <% } %>
          </tbody>
          <tfoot>
            <tr class="border-secondary">
              <td colspan="5" class="text-end small text-muted align-top pt-2">Live calculation <span class="d-none d-md-inline">(rows with a milestone name)</span></td>
              <td class="text-end small align-top pt-2">
                <div id="pt-live-totals" class="d-inline-block text-start px-2 py-2 rounded border border-secondary border-opacity-50 bg-dark bg-opacity-25" style="min-width: 11rem;">
                  <div class="mb-1"><span class="text-muted">% total</span> <strong id="pt-live-sum-pct" class="text-light ms-1">0.00</strong></div>
                  <div class="mb-1"><span class="text-muted">Amount total</span> <strong id="pt-live-sum-amt" class="text-warning ms-1">₹0</strong></div>
                  <div class="text-muted" style="font-size: 0.75rem;">At 100%, row totals should equal <span class="text-warning"><%= ct > 0 ? ('₹' + Math.round(ct).toLocaleString('en-IN')) : '₹0' %></span></div>
                  <div id="pt-live-hint" class="small mt-1 mb-0" aria-live="polite"></div>
                </div>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
      <template id="portal-pt-row-template">
        <tr class="js-pt-row">
          <td class="text-muted small js-pt-row-num">1</td>
          <td>
            <input type="hidden" name="pt_basis_0" value="TOTAL" class="js-pt-basis" />
            <input type="text" name="pt_label_0" class="form-control form-control-sm bg-dark text-light border-secondary js-pt-label" value="" placeholder="Milestone name" autocomplete="off" />
          </td>
          <td><input type="number" name="pt_pct_0" step="0.01" min="0" max="100" class="form-control form-control-sm bg-dark text-light border-secondary js-pt-pct" value="" placeholder="%" /></td>
          <td><input type="date" name="pt_due_0" class="form-control form-control-sm bg-dark text-light border-secondary js-pt-due" value="" title="Optional target date for this milestone" /></td>
          <td class="text-end small pt-admin-preview text-muted" data-pt-preview-row="0">—</td>
          <td class="text-nowrap text-center">
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 me-0 js-pt-add-after" title="Add row below"><i class="bi bi-plus-lg" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 js-pt-move-up" title="Move up"><i class="bi bi-arrow-up" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 js-pt-move-down" title="Move down"><i class="bi bi-arrow-down" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1 js-pt-remove" title="Remove row"><i class="bi bi-trash" aria-hidden="true"></i></button>
          </td>
        </tr>
      </template>
      <button type="submit" class="btn btn-gold btn-sm">Save payment terms</button>
    </form>
    <form method="post" action="/portal/admin/projects/<%= pid %>/payment-terms" class="d-inline" onsubmit="return confirm('Reset this project to the default studio payment schedule?');">
      <input type="hidden" name="reset_payment_terms" value="1" />
      <button type="submit" class="btn btn-outline-secondary btn-sm">Reset to default breakdown</button>
    </form>
    <script>
    (function () {
      var form = document.getElementById('portal-payment-terms-form');
      if (!form) return;
      var tbody = document.getElementById('portal-payment-terms-tbody');
      var tpl = document.getElementById('portal-pt-row-template');
      if (!tbody || !tpl) return;

      var ct = parseFloat(form.getAttribute('data-contract-total'));
      if (!Number.isFinite(ct)) ct = 0;
      var maxRows = parseInt(form.getAttribute('data-pt-max-rows'), 10);
      if (!Number.isFinite(maxRows) || maxRows < 1) maxRows = 10;

      function rowCount() {
        return tbody.querySelectorAll('tr.js-pt-row').length;
      }

      function reindexRows() {
        var rows = tbody.querySelectorAll('tr.js-pt-row');
        var n = rows.length;
        rows.forEach(function (tr, i) {
          var num = tr.querySelector('.js-pt-row-num');
          if (num) num.textContent = String(i + 1);
          var basis = tr.querySelector('input.js-pt-basis');
          if (basis) basis.name = 'pt_basis_' + i;
          var label = tr.querySelector('.js-pt-label');
          if (label) label.name = 'pt_label_' + i;
          var pct = tr.querySelector('.js-pt-pct');
          if (pct) pct.name = 'pt_pct_' + i;
          var due = tr.querySelector('.js-pt-due');
          if (due) due.name = 'pt_due_' + i;
          var previewEl = tr.querySelector('.pt-admin-preview');
          if (previewEl) previewEl.setAttribute('data-pt-preview-row', String(i));

          var addBtn = tr.querySelector('.js-pt-add-after');
          if (addBtn) addBtn.disabled = n >= maxRows;
          var upBtn = tr.querySelector('.js-pt-move-up');
          if (upBtn) upBtn.disabled = i === 0;
          var downBtn = tr.querySelector('.js-pt-move-down');
          if (downBtn) downBtn.disabled = i === n - 1;
          var rmBtn = tr.querySelector('.js-pt-remove');
          if (rmBtn) rmBtn.disabled = n <= 1;
        });
      }

      function parsePct(v) {
        if (v === '' || v == null) return null;
        var n = parseFloat(String(v).replace(/,/g, ''));
        return Number.isFinite(n) ? n : null;
      }

      function formatInr(n) {
        return '₹' + Math.round(n).toLocaleString('en-IN');
      }

      function recalc() {
        var sumPct = 0;
        var sumAmtRounded = 0;
        var filledCount = 0;
        var n = rowCount();
        for (var i = 0; i < n; i++) {
          var labelEl = form.querySelector('[name="pt_label_' + i + '"]');
          var pctEl = form.querySelector('[name="pt_pct_' + i + '"]');
          var previewEl = form.querySelector('[data-pt-preview-row="' + i + '"]');
          var pct = pctEl ? parsePct(pctEl.value) : null;
          var hasLabel = labelEl && String(labelEl.value || '').trim() !== '';
          var filled = hasLabel && pct !== null;
          if (previewEl) {
            if (filled) {
              var rupees = Math.round((ct * pct) / 100);
              previewEl.textContent = formatInr(rupees);
              previewEl.classList.add('text-warning');
              previewEl.classList.remove('text-muted');
              sumPct += pct;
              sumAmtRounded += rupees;
              filledCount += 1;
            } else {
              previewEl.textContent = '—';
              previewEl.classList.remove('text-warning');
              previewEl.classList.add('text-muted');
            }
          }
        }
        var pctElOut = document.getElementById('pt-live-sum-pct');
        var amtElOut = document.getElementById('pt-live-sum-amt');
        var box = document.getElementById('pt-live-totals');
        var hint = document.getElementById('pt-live-hint');
        if (pctElOut) pctElOut.textContent = sumPct.toFixed(2);
        if (amtElOut) amtElOut.textContent = formatInr(sumAmtRounded);
        if (box) {
          box.classList.remove('border-success', 'border-warning', 'border-danger');
          var pctOk = Math.abs(sumPct - 100) < 0.051;
          var amtOk = ct > 0 && pctOk && Math.abs(sumAmtRounded - Math.round(ct)) <= 1;
          if (filledCount === 0) {
            /* neutral */
          } else if (pctOk && (ct <= 0 || amtOk)) {
            box.classList.add('border-success');
          } else {
            box.classList.add('border-warning');
          }
        }
        if (hint) {
          hint.className = 'small mt-1 mb-0';
          if (filledCount === 0) {
            hint.textContent = '';
          } else if (ct <= 0) {
            hint.textContent = 'Contract total is ₹0 until the quotation is approved.';
            hint.classList.add('text-muted');
          } else if (pctOk && Math.abs(sumAmtRounded - Math.round(ct)) <= 1) {
            hint.textContent = 'Named milestones total 100% and amounts match the contract total.';
            hint.classList.add('text-success');
          } else if (!pctOk) {
            hint.textContent = 'Save requires exactly 100% across named milestones (currently ' + sumPct.toFixed(2) + '%).';
            hint.classList.add('text-warning');
          } else {
            hint.textContent = 'Check percentages — amount total should match the contract total at 100%.';
            hint.classList.add('text-warning');
          }
        }
      }

      function addRowAfter(tr) {
        if (rowCount() >= maxRows) return;
        var frag = tpl.content.cloneNode(true);
        var newTr = frag.querySelector('tr');
        if (!newTr) return;
        tr.parentNode.insertBefore(newTr, tr.nextSibling);
        reindexRows();
        recalc();
      }

      function moveRowUp(tr) {
        var prev = tr.previousElementSibling;
        if (!prev || !prev.classList.contains('js-pt-row')) return;
        tr.parentNode.insertBefore(tr, prev);
        reindexRows();
        recalc();
      }

      function moveRowDown(tr) {
        var next = tr.nextElementSibling;
        if (!next || !next.classList.contains('js-pt-row')) return;
        tr.parentNode.insertBefore(next, tr);
        reindexRows();
        recalc();
      }

      function removeRow(tr) {
        if (rowCount() <= 1) {
          tr.querySelectorAll('.js-pt-label, .js-pt-pct, .js-pt-due').forEach(function (el) {
            el.value = '';
          });
          reindexRows();
          recalc();
          return;
        }
        tr.remove();
        reindexRows();
        recalc();
      }

      tbody.addEventListener('click', function (e) {
        var btn = e.target.closest('button');
        if (!btn || !tbody.contains(btn)) return;
        var tr = btn.closest('tr.js-pt-row');
        if (!tr) return;
        if (btn.classList.contains('js-pt-add-after')) {
          e.preventDefault();
          addRowAfter(tr);
        } else if (btn.classList.contains('js-pt-move-up')) {
          e.preventDefault();
          moveRowUp(tr);
        } else if (btn.classList.contains('js-pt-move-down')) {
          e.preventDefault();
          moveRowDown(tr);
        } else if (btn.classList.contains('js-pt-remove')) {
          e.preventDefault();
          removeRow(tr);
        }
      });

      form.addEventListener('input', function () {
        recalc();
      });
      form.addEventListener('change', function () {
        recalc();
      });
      reindexRows();
      recalc();
    })();
    </script>
    <% } else { %>
    <% if (pt.intro) { %><p class="text-light mb-3" style="white-space:pre-wrap"><%= pt.intro %></p><% } %>
    <div class="small mb-3 p-2 rounded border border-secondary border-opacity-25 bg-dark bg-opacity-25">
      <div class="text-muted mb-1">What the percentages apply to</div>
      <ul class="mb-0 ps-3">
        <li>Approved quotation base: <strong class="text-warning">₹<%= qb.toLocaleString('en-IN') %></strong></li>
        <li>Approved extra costs (variations): <strong class="text-warning">₹<%= varAmt.toLocaleString('en-IN') %></strong></li>
        <li class="fw-semibold text-light">Contract total (100% of schedule): <strong class="text-warning">₹<%= ct.toLocaleString('en-IN') %></strong></li>
      </ul>
    </div>
    <p class="small text-muted mb-2">Each milestone is a percentage of the <strong>contract total</strong> above (not the quotation alone). When percentages total 100%, the indicative amounts below sum to that contract total. Final invoices follow your agreement with the studio.</p>
    <div class="table-responsive">
      <table class="table table-dark table-sm table-bordered border-secondary mb-0">
        <thead>
          <tr class="text-muted small">
            <th style="width:2.5rem">#</th>
            <th>Milestone</th>
            <th class="text-end" style="width:5rem">% of contract</th>
            <th style="width:9rem">Due date</th>
            <th class="text-end" style="width:10rem">Indicative (₹)</th>
          </tr>
        </thead>
        <tbody>
          <% var sumAmt = 0;
          var sumPct = 0;
          (pt.items || []).forEach(function(row, idx) {
            var amt = ct * (Number(row.percent) || 0) / 100;
            sumAmt += amt;
            sumPct += Number(row.percent) || 0;
            var dueClient = '—';
            if (row.dueDate) {
              var ddc = new Date(row.dueDate + 'T12:00:00');
              dueClient = !isNaN(ddc.getTime()) ? ddc.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : row.dueDate;
            }
          %>
          <tr>
            <td class="text-muted"><%= idx + 1 %></td>
            <td><%= row.label %></td>
            <td class="text-end"><%= row.percent %>%</td>
            <td class="small"><%= dueClient %></td>
            <td class="text-end serif text-warning">₹<%= Math.round(amt).toLocaleString('en-IN') %></td>
          </tr>
          <% }); %>
        </tbody>
        <% if ((pt.items || []).length) {
          var pctOk = Math.abs(sumPct - 100) < 0.05;
          var sumRounded = Math.round(sumAmt);
          var ctRounded = Math.round(ct);
          var sumMatchesContract = ct > 0 && pctOk && Math.abs(sumRounded - ctRounded) <= 1;
        %>
        <tfoot>
          <tr class="border-secondary">
            <td colspan="4" class="text-end small text-muted">Sum of milestone amounts (indicative)</td>
            <td class="text-end serif text-warning">₹<%= sumRounded.toLocaleString('en-IN') %></td>
          </tr>
          <% if (ct > 0 && sumMatchesContract) { %>
          <tr class="border-0">
            <td colspan="5" class="small text-success pt-0 pb-0">Matches contract total ₹<%= ctRounded.toLocaleString('en-IN') %> (percentages total 100%).</td>
          </tr>
          <% } else if (ct > 0 && !pctOk) { %>
          <tr class="border-0">
            <td colspan="5" class="small text-warning pt-0 pb-0">Milestone percentages total <%= sumPct.toFixed(2) %>% — they must total <strong>100%</strong> for the sum to match the contract total.</td>
          </tr>
          <% } else if (ct > 0 && pctOk) { %>
          <tr class="border-0">
            <td colspan="5" class="small text-warning pt-0 pb-0">Percentages total 100%, but the indicative sum (₹<%= sumRounded.toLocaleString('en-IN') %>) should equal contract total ₹<%= ctRounded.toLocaleString('en-IN') %>; report this to the studio if it does not.</td>
          </tr>
          <% } %>
        </tfoot>
        <% } %>
      </table>
    </div>
    <% if (!(pt.items || []).length) { %><p class="text-muted small mb-0 mt-2">No milestones configured.</p><% } %>
    <% } %>

  <div class="border border-secondary border-opacity-50 rounded mt-4 p-3 p-md-4 bg-dark bg-opacity-25">
    <h6 class="text-warning text-uppercase mb-3" style="letter-spacing:0.06em;font-size:0.75rem">
      <i class="bi bi-file-text me-2"></i>Payment terms — terms &amp; conditions
    </h6>
    <ul class="small text-muted ps-3 mb-0">
      <li class="mb-2">
        Payments not received within <strong class="text-light">2 days</strong> from the due date will result in delays to the timeline, for which the Service Provider shall not be held responsible.
      </li>
      <li class="mb-0">
        The payment can be increased and decreased according to the ongoing addition and cancellation of requirements.
      </li>
    </ul>
  </div>

  <div class="border border-secondary border-opacity-50 rounded mt-3 p-3 p-md-4 bg-dark bg-opacity-25">
    <h6 class="text-warning text-uppercase mb-3" style="letter-spacing:0.06em;font-size:0.75rem">
      <i class="bi bi-x-circle me-2"></i>Cancellation policies
    </h6>
    <ul class="small text-muted ps-3 mb-0">
      <li class="mb-2">Booking amount is not refundable.</li>
      <li class="mb-0">Project cancellation will not be permitted after commencement.</li>
    </ul>
  </div>

  <div class="border border-secondary border-opacity-50 rounded mt-3 p-3 p-md-4 bg-dark bg-opacity-25">
    <h6 class="text-warning text-uppercase mb-3" style="letter-spacing:0.06em;font-size:0.75rem">
      <i class="bi bi-journal-check me-2"></i>Ownership, termination &amp; disputes
    </h6>
    <div class="mb-3 pb-3 border-bottom border-secondary border-opacity-25">
      <div class="small text-warning fw-semibold mb-2 text-uppercase" style="letter-spacing:0.04em;font-size:0.7rem">Ownership and delivery</div>
      <ul class="small text-muted ps-3 mb-0">
        <li class="mb-2">All materials and designs created by the Service Provider remain the property of the Service Provider until full payment has been made.</li>
        <li class="mb-0">The furniture will be delivered and installed at the Customer&apos;s location once all applicable payments are received.</li>
      </ul>
    </div>
    <div class="mb-3 pb-3 border-bottom border-secondary border-opacity-25">
      <div class="small text-warning fw-semibold mb-2 text-uppercase" style="letter-spacing:0.04em;font-size:0.7rem">Termination</div>
      <p class="small text-muted mb-0">Either party may terminate this Agreement if the other party fails to comply with any material terms of this Agreement. Written notice must be provided, and all services rendered up to the date of termination must be paid for.</p>
    </div>
    <div>
      <div class="small text-warning fw-semibold mb-2 text-uppercase" style="letter-spacing:0.04em;font-size:0.7rem">Dispute resolution</div>
      <p class="small text-muted mb-0">Any disputes arising under this Agreement will be settled through mutual consultation and, if necessary, through mediation or arbitration as agreed upon by both parties.</p>
    </div>
  </div>

<% if (!embed) { %>
  </div>
</div>
<% } else { %>
</section>
<% } %>
