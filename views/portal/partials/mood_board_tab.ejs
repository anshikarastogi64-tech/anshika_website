<%
  const mode = typeof moodBoardMode !== 'undefined' ? moodBoardMode : 'designer';
  const list = typeof moodBoardFiles !== 'undefined' && Array.isArray(moodBoardFiles) ? moodBoardFiles : [];
  const proj = typeof project !== 'undefined' ? project : null;
  const uploadAction = mode === 'admin'
    ? '/portal/admin/projects/' + proj.id + '/mood-board'
    : '/portal/designer/projects/' + proj.id + '/mood-board';
  const deleteBase = mode === 'admin'
    ? '/portal/admin/projects/' + proj.id + '/media/'
    : '/portal/designer/projects/' + proj.id + '/media/';
  function moodFmtSize(n) {
    if (n == null || n === '') return '';
    var b = Number(n);
    if (!b || isNaN(b)) return '';
    if (b < 1024) return b + ' B';
    if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
    return (b / (1024 * 1024)).toFixed(1) + ' MB';
  }
  function moodIsImageThumb(m) {
    var t = (m.type || '').toUpperCase();
    if (t === 'VIDEO' || t === 'DOCUMENT') return false;
    var n = ((m.file_name || m.url || '') + '').toLowerCase();
    return /\.(jpg|jpeg|png|gif|webp|bmp|svg)$/.test(n);
  }
  function moodIsPdf(m) {
    var n = ((m.file_name || m.url || '') + '').toLowerCase();
    return (m.type || '').toUpperCase() === 'DOCUMENT' && (n.endsWith('.pdf') || (m.url || '').toLowerCase().indexOf('.pdf') !== -1);
  }
%>
<div class="tab-pane fade<%= typeof moodBoardTabPaneClass !== 'undefined' ? moodBoardTabPaneClass : '' %>" id="tab-mood-board" role="tabpanel">
  <div class="card card-portal mb-4">
    <div class="card-header serif text-warning">Mood board</div>
    <div class="card-body">
      <% if (mode === 'client') { %>
      <p class="small text-muted mb-3">Inspiration and reference files shared by your design team (view only).</p>
      <% } else { %>
      <p class="small text-muted mb-3">Upload inspiration and reference files (images, PDF, Office documents, etc.). Maximum <strong>50&nbsp;MB</strong> per file.</p>
      <form method="post" action="<%= uploadAction %>" enctype="multipart/form-data" class="mood-board-upload-form mb-4">
        <div class="row g-3 align-items-end">
          <div class="col-12 col-lg">
            <label class="form-label small mb-1 text-light" for="moodBoardFileInput">File</label>
            <input id="moodBoardFileInput" type="file" name="file" class="form-control bg-dark text-light border-secondary w-100" required />
          </div>
          <div class="col-12 col-lg-auto">
            <button type="submit" class="btn btn-gold w-100 px-4 py-2">Upload</button>
          </div>
        </div>
      </form>
      <% } %>
      <% if (list.length === 0) { %>
      <p class="text-muted mb-0">No mood board files yet.</p>
      <% } else { %>
      <div class="vault-grid mood-board-grid">
        <% list.slice().sort(function(a,b) { return new Date(b.created_at||0) - new Date(a.created_at||0); }).forEach(function(m) {
          var isVideo = (m.type || '') === 'VIDEO';
          var isPdf = moodIsPdf(m);
          var imgThumb = moodIsImageThumb(m);
          var by = (m.uploaded_by_role || '').toUpperCase();
        %>
        <div class="vault-item-wrapper mb-3">
          <div class="vault-item rounded overflow-hidden border border-secondary border-opacity-25">
            <% if (isVideo) { %>
            <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center" style="min-height:140px">
              <i class="bi bi-film text-warning" style="font-size:2rem"></i>
            </div>
            <% } else if (isPdf) { %>
            <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center" style="min-height:140px">
              <i class="bi bi-file-earmark-pdf-fill text-danger" style="font-size:2rem"></i>
            </div>
            <% } else if (imgThumb) { %>
            <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center">
              <img src="<%= m.url %>" alt="" loading="lazy" style="max-height:180px;object-fit:contain;width:100%" />
            </div>
            <% } else { %>
            <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center" style="min-height:140px">
              <i class="bi bi-file-earmark text-secondary" style="font-size:2rem"></i>
            </div>
            <% } %>
            <div class="p-2 small">
              <a href="<%= m.url %>" class="text-warning text-decoration-none d-block text-truncate" title="<%= m.file_name || m.url %>" target="_blank" rel="noopener"><%= m.file_name || 'Download' %></a>
              <div class="text-muted mt-1">
                <%= new Date(m.created_at).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' }) %>
                <% if (moodFmtSize(m.file_size)) { %> · <%= moodFmtSize(m.file_size) %><% } %>
                · <%= by === 'ADMIN' ? 'Admin' : by === 'DESIGNER' ? 'Designer' : 'Team' %>
              </div>
              <% if (mode !== 'client') { %>
              <form method="post" action="<%= deleteBase %><%= m.id %>/delete" class="mt-2 mb-0" onsubmit="return confirm('Delete this file?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>
</div>
<style>
.mood-board-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem; }
.mood-board-upload-form .form-control[type="file"] { min-height: 38px; }
</style>
