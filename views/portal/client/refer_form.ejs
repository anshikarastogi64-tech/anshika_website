<h1 class="serif text-warning mb-4">Refer Friends & Family</h1>
<p class="text-muted">Share your experience. We'll reach out to them.</p>
<% if (typeof query !== 'undefined' && query && query.error) { %><div class="alert alert-warning"><%= query.error %></div><% } %>
<form method="post" action="/portal/client/refer">
  <div class="mb-3">
    <label class="form-label">Name</label>
    <input type="text" name="name" class="form-control bg-dark text-light border-secondary" required />
  </div>
  <div class="mb-3">
    <label class="form-label">Phone</label>
    <input type="tel" name="phone_number" class="form-control bg-dark text-light border-secondary" required placeholder="e.g. 9876543210" />
  </div>
  <div class="mb-3">
    <label class="form-label">Email (optional)</label>
    <input type="email" name="email" class="form-control bg-dark text-light border-secondary" />
  </div>
  <button type="submit" class="btn btn-gold">Submit referral</button>
  <a href="/portal/client" class="btn btn-outline-gold ms-2">Cancel</a>
</form>
