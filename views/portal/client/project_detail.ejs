<h1 class="serif text-warning mb-4"><%= project.title %></h1>
<p class="mb-3">Progress: <strong><%= typeof lifecycleHeadline === 'function' ? lifecycleHeadline(project) : (LIFECYCLE_STAGES[project.current_stage] ? LIFECYCLE_STAGES[project.current_stage].name : project.current_stage) %></strong></p>
<% var tabOrderClient = ['updates','timelines','mood-board','design-ideas','vault','material-selection','daily','finance','warranty','vastu','other-docs','messages','meetings'];
   var cTabs = typeof clientAllowedTabs !== 'undefined' && clientAllowedTabs ? clientAllowedTabs : {};
   tabOrderClient.forEach(function(k) { if (cTabs[k] === undefined) cTabs[k] = true; });
   var anyClientTab = tabOrderClient.some(function(k) { return cTabs[k]; });
   var firstVis = tabOrderClient.find(function(k) { return cTabs[k]; }) || 'updates';
%>
<% if (!anyClientTab) { %>
<div class="alert alert-warning border border-warning text-dark">No sections are enabled for your account on this project. Please contact the studio.</div>
<% } else { %>
<% if (cTabs.messages && typeof clientMessageAlerts !== 'undefined' && clientMessageAlerts.length) { %>
<div class="portal-message-alerts mb-3">
  <% clientMessageAlerts.forEach(function(a) {
       var pr = String(a.priority || '').toUpperCase();
       var alertClass = pr === 'CRITICAL' ? 'alert-danger border border-danger' : (pr === 'URGENT' ? 'alert-warning border border-warning text-dark' : 'alert-info border border-info text-dark');
       var label = pr === 'CRITICAL' ? 'Critical' : (pr === 'URGENT' ? 'Urgent' : 'Important');
  %>
  <div class="alert <%= alertClass %> mb-2 shadow-sm" role="alert">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
      <div class="flex-grow-1 min-w-0">
        <strong class="d-block mb-1"><%= label %> — studio message</strong>
        <% if (a.author_name) { %><span class="small opacity-75 d-block mb-1">From <%= a.author_name %></span><% } %>
        <div class="mb-0" style="white-space:pre-wrap;word-break:break-word"><%= a.body %></div>
      </div>
      <% if (!readOnly) { %>
      <form method="post" action="/portal/client/projects/<%= project.id %>/messages/<%= a.id %>/ack" class="flex-shrink-0">
        <button type="submit" class="btn btn-sm btn-outline-dark">Dismiss from top</button>
      </form>
      <% } else { %>
      <span class="small text-muted flex-shrink-0">Mirror</span>
      <% } %>
    </div>
    <div class="mt-2 mb-0 small"><a href="#tab-messages" class="alert-link">Open Messages</a></div>
  </div>
  <% }); %>
</div>
<% } %>
<ul class="nav nav-tabs portal-tabs mb-3" id="projectTabs" role="tablist">
  <% if (cTabs.updates) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'updates' ? ' active' : '' %>" id="tab-updates-btn" data-bs-toggle="tab" data-bs-target="#tab-updates" type="button" role="tab">Updates & Progress</button>
  </li>
  <% } %>
  <% if (cTabs.timelines) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'timelines' ? ' active' : '' %>" id="tab-timelines-btn" data-bs-toggle="tab" data-bs-target="#tab-timelines" type="button" role="tab">Timelines</button>
  </li>
  <% } %>
  <% if (cTabs['mood-board']) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'mood-board' ? ' active' : '' %>" id="tab-mood-board-btn" data-bs-toggle="tab" data-bs-target="#tab-mood-board" type="button" role="tab">Mood board</button>
  </li>
  <% } %>
  <% if (cTabs['design-ideas']) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'design-ideas' ? ' active' : '' %>" id="tab-design-ideas-btn" data-bs-toggle="tab" data-bs-target="#tab-design-ideas" type="button" role="tab">Your vision</button>
  </li>
  <% } %>
  <% if (cTabs.vault) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'vault' ? ' active' : '' %>" id="tab-vault-btn" data-bs-toggle="tab" data-bs-target="#tab-vault" type="button" role="tab">Design Vault</button>
  </li>
  <% } %>
  <% if (cTabs['material-selection']) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'material-selection' ? ' active' : '' %>" id="tab-material-selection-btn" data-bs-toggle="tab" data-bs-target="#tab-material-selection" type="button" role="tab">Material Selection</button>
  </li>
  <% } %>
  <% if (cTabs.daily) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'daily' ? ' active' : '' %>" id="tab-daily-btn" data-bs-toggle="tab" data-bs-target="#tab-daily" type="button" role="tab">Daily Updates</button>
  </li>
  <% } %>
  <% if (cTabs.finance) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'finance' ? ' active' : '' %>" id="tab-finance-btn" data-bs-toggle="tab" data-bs-target="#tab-finance" type="button" role="tab">Finance</button>
  </li>
  <% } %>
  <% if (cTabs.warranty) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'warranty' ? ' active' : '' %>" id="tab-warranty-btn" data-bs-toggle="tab" data-bs-target="#tab-warranty" type="button" role="tab">Warranty &amp; Guarantee</button>
  </li>
  <% } %>
  <% if (cTabs.vastu) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'vastu' ? ' active' : '' %>" id="tab-vastu-btn" data-bs-toggle="tab" data-bs-target="#tab-vastu" type="button" role="tab">Vastu Documents</button>
  </li>
  <% } %>
  <% if (cTabs['other-docs']) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'other-docs' ? ' active' : '' %>" id="tab-other-docs-btn" data-bs-toggle="tab" data-bs-target="#tab-other-docs" type="button" role="tab">Other documents</button>
  </li>
  <% } %>
  <% if (cTabs.messages) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'messages' ? ' active' : '' %>" id="tab-messages-btn" data-bs-toggle="tab" data-bs-target="#tab-messages" type="button" role="tab">Messages</button>
  </li>
  <% } %>
  <% if (cTabs.meetings) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link<%= firstVis === 'meetings' ? ' active' : '' %>" id="tab-meetings-btn" data-bs-toggle="tab" data-bs-target="#tab-meetings" type="button" role="tab">Meetings</button>
  </li>
  <% } %>
</ul>
<div class="tab-content" id="projectTabsContent">
  <% if (cTabs.updates) { %>
  <div class="tab-pane fade<%= firstVis === 'updates' ? ' show active' : '' %>" id="tab-updates" role="tabpanel">
    <!-- Progress stepper -->
    <div class="card card-portal mb-4">
      <div class="card-header">Progress</div>
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2">
          <% LIFECYCLE_STAGES.forEach(function(s) {
            var done = project.lifecycle_completed && project.lifecycle_completed.indexOf(s.index) !== -1;
            var on = project.lifecycle_active && project.lifecycle_active.indexOf(s.index) !== -1;
            var badgeCls = done ? 'bg-success' : (on ? 'bg-warning text-dark' : 'bg-secondary');
          %>
          <span class="badge <%= badgeCls %>" title="<%= s.description %>"><%= s.name %></span>
          <% }); %>
        </div>
      </div>
    </div>
    <!-- Live Site View -->
    <div class="card card-portal mb-4">
      <div class="card-header">Live Site View</div>
      <div class="card-body">
        <% if (project.rtsp_link) { %>
        <div id="cctv-container" class="ratio ratio-16x9 bg-dark rounded">
          <p class="text-muted d-flex align-items-center justify-content-center m-0">Loading stream…</p>
        </div>
        <script>
(function(){
  var projectId = '<%= project.id %>';
  fetch('/portal/api/cctv/' + projectId, { credentials: 'same-origin' })
    .then(function(r){ return r.json(); })
    .then(function(d){
      var el = document.getElementById('cctv-container');
      if (d.url && !d.useRtsp && d.token) {
        if (typeof ImouPlayer !== 'undefined') {
          new ImouPlayer({ id: 'cctv-container', url: d.url, token: d.token, width: el.offsetWidth, height: el.offsetHeight });
        } else {
          el.innerHTML = '<p class="text-muted m-0">Stream ready. Add Imou H5 Player SDK for playback.</p>';
        }
      } else if (d.url && d.useRtsp) {
        el.innerHTML = '<p class="text-muted m-0">Live stream (RTSP) is configured. Use Imou cloud or a compatible player to view.</p>';
      } else {
        el.innerHTML = '<p class="text-muted m-0">Live stream offline</p>';
      }
    })
    .catch(function(){ document.getElementById('cctv-container').innerHTML = '<p class="text-muted m-0">Live stream offline</p>'; });
})();
        </script>
        <% } else { %>
        <p class="text-muted mb-0">Live stream not configured. Your designer can add a camera link to this project.</p>
        <% } %>
      </div>
    </div>
    <p><button type="button" class="btn btn-outline-gold btn-sm" onclick="window.switchToDailyUpdates && window.switchToDailyUpdates()">View Project Progress</button></p>
  </div>
  <% } %>
  <% if (cTabs.timelines) { %>
  <%- include('../partials/project_timelines', { project, timelineExtensions: typeof timelineExtensions !== 'undefined' ? timelineExtensions : [], timelinesRole: 'client', timelineBasePath: '', timelineTabPaneClass: firstVis === 'timelines' ? ' show active' : '' }) %>
  <% } %>
  <% if (cTabs['mood-board']) { %>
  <%- include('../partials/mood_board_tab', { project, moodBoardFiles: typeof moodBoardFiles !== 'undefined' ? moodBoardFiles : [], moodBoardMode: 'client', moodBoardTabPaneClass: firstVis === 'mood-board' ? ' show active' : '' }) %>
  <% } %>
  <% if (cTabs['design-ideas']) { %>
  <%- include('../partials/project_design_ideas_tab', { project, designIdeaAreas: typeof designIdeaAreas !== 'undefined' ? designIdeaAreas : [], designIdeasWithComments: typeof designIdeasWithComments !== 'undefined' ? designIdeasWithComments : [], ideasMode: 'client', readOnly: typeof readOnly !== 'undefined' ? readOnly : false, ideasTabPaneClass: firstVis === 'design-ideas' ? ' show active' : '', query: typeof query !== 'undefined' ? query : {} }) %>
  <% } %>
  <% if (cTabs.vault) { %>
  <div class="tab-pane fade<%= firstVis === 'vault' ? ' show active' : '' %>" id="tab-vault" role="tabpanel">
    <%- include('../partials/design_vault', { mediaByCategory: typeof mediaByCategory !== 'undefined' ? mediaByCategory : {}, byYearMonth: typeof byYearMonth !== 'undefined' ? byYearMonth : {}, vaultMediaList: typeof vaultMediaList !== 'undefined' ? vaultMediaList : [], projectDesigns: typeof projectDesigns !== 'undefined' ? projectDesigns : [], project, readOnly: typeof readOnly !== 'undefined' ? readOnly : false, showDailyOnly: false }) %>
  </div>
  <% } %>
  <% if (cTabs['material-selection']) { %>
  <div class="tab-pane fade<%= firstVis === 'material-selection' ? ' show active' : '' %>" id="tab-material-selection" role="tabpanel">
    <%- include('../partials/material_selection_tab', { project, materialSelections: typeof materialSelections !== 'undefined' ? materialSelections : [], readOnly: typeof readOnly !== 'undefined' ? readOnly : false }) %>
  </div>
  <% } %>
  <% if (cTabs.daily) { %>
  <div class="tab-pane fade<%= firstVis === 'daily' ? ' show active' : '' %>" id="tab-daily" role="tabpanel">
    <%- include('../partials/design_vault', { mediaByCategory: typeof mediaByCategory !== 'undefined' ? mediaByCategory : {}, byYearMonth: typeof byYearMonth !== 'undefined' ? byYearMonth : {}, vaultMediaList: typeof vaultMediaList !== 'undefined' ? vaultMediaList : [], projectDesigns: typeof projectDesigns !== 'undefined' ? projectDesigns : [], project, readOnly: typeof readOnly !== 'undefined' ? readOnly : false, dailyUpdates: typeof dailyUpdates !== 'undefined' ? dailyUpdates : [], showDailyOnly: true, includeVaultGalleryModal: !cTabs.vault }) %>
  </div>
  <% } %>
  <% if (cTabs.finance) { %>
  <div class="tab-pane fade<%= firstVis === 'finance' ? ' show active' : '' %>" id="tab-finance" role="tabpanel">
    <div class="card card-portal mb-4 border-warning border-opacity-25">
      <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
        <span class="serif text-warning mb-0">Your project value &amp; balance</span>
        <% if (readOnly) { %><span class="badge bg-secondary">Preview (mirror)</span><% } %>
      </div>
      <div class="card-body">
        <div class="row g-3 mb-4">
          <div class="col-md-4">
            <div class="rounded-3 p-3 h-100" style="background: rgba(212, 175, 55, 0.08); border: 1px solid rgba(212, 175, 55, 0.25);">
              <div class="small text-muted text-uppercase mb-1" style="letter-spacing: 0.04em;">Contract total</div>
              <p class="serif fs-4 text-warning mb-0" id="projectTotal">₹<%= (typeof total !== 'undefined' ? total : 0).toLocaleString('en-IN') %></p>
              <p class="small text-muted mb-0 mt-2">Approved quotation plus approved extra costs.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="rounded-3 p-3 h-100 bg-dark border border-secondary">
              <div class="small text-muted text-uppercase mb-1" style="letter-spacing: 0.04em;">Payments confirmed for you</div>
              <p class="serif fs-4 text-success mb-0">₹<%= (typeof financePaidPublished !== 'undefined' ? financePaidPublished : 0).toLocaleString('en-IN') %></p>
              <p class="small text-muted mb-0 mt-2">Only entries your studio has shared appear here.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="rounded-3 p-3 h-100" style="background: rgba(255, 193, 7, 0.06); border: 1px solid rgba(255, 193, 7, 0.35);">
              <div class="small text-muted text-uppercase mb-1" style="letter-spacing: 0.04em;">Balance to pay</div>
              <p class="serif fs-4 text-warning mb-0">₹<%= (typeof financeBalanceDue !== 'undefined' ? financeBalanceDue : 0).toLocaleString('en-IN') %></p>
              <p class="small text-muted mb-0 mt-2">Outstanding after shared payments. Questions? Message your studio.</p>
            </div>
          </div>
        </div>
        <%- include('../partials/payment_finance_panel', { project, paymentScheduleProgress: typeof paymentScheduleProgress !== 'undefined' ? paymentScheduleProgress : null, showPaymentScheduleExplain: false, paymentTerms: typeof paymentTerms !== 'undefined' ? paymentTerms : null, quotationBaseForTerms: typeof quotationBaseForTerms !== 'undefined' ? quotationBaseForTerms : 0, contractTotal: typeof total !== 'undefined' ? total : 0, paymentTermsEditMode: false }) %>
        <% if (quotation) { %>
        <p>Quotation (base): ₹<%= quotation.base_total.toLocaleString() %> – Status: <strong><%= quotation.status %></strong></p>
        <% if (quotation.pdf_url) { %><p class="mb-2"><a href="<%= quotation.pdf_url %>" class="text-warning" data-portal-pdf="1" data-portal-pdf-name="Quotation">View quotation PDF</a></p><% } %>
        <% if (!readOnly && quotation.status === 'PENDING') { %>
        <button type="button" class="btn btn-gold btn-sm" data-quotation-id="<%= quotation.id %>" onclick="approveQuotation(this)">Approve Quotation</button>
        <% } %>
        <h6 class="mt-4">Extra costs / Variations</h6>
        <p class="small text-muted mb-2">Comments are preserved in order. After a cost is approved, comment history is available via the icon. You can Approve, Reject (reason required), or add a Comment.</p>
        <ul class="list-unstyled">
          <% extraCosts.forEach(function(ec) { %>
          <li class="border-bottom border-secondary py-2" id="ec-<%= ec.id %>">
            <% if (ec.status === 'SUPERSEDED') { %>
            <span class="text-muted"><%= ec.description %> – ₹<%= ec.amount.toLocaleString() %> – <strong>Superseded</strong> (replaced by updated cost)</span>
            <% if (ec.comments && ec.comments.length) { %>
            <span class="ms-2" title="Comment history" data-comments="<%= encodeURIComponent(JSON.stringify(ec.comments)) %>" onclick="showCommentHistory(this)" style="cursor:pointer"><i class="bi bi-chat-left-text text-warning"></i></span>
            <% } %>
            <% } else { %>
            <%= ec.description %> – ₹<%= ec.amount.toLocaleString() %> – <strong><%= ec.status %></strong>
            <% if (ec.status === 'APPROVED' && ec.comments && ec.comments.length) { %>
            <span class="ms-2" title="View comment history" data-comments="<%= encodeURIComponent(JSON.stringify(ec.comments)) %>" onclick="showCommentHistory(this)" style="cursor:pointer"><i class="bi bi-chat-left-text text-warning"></i></span>
            <% } else if (ec.status !== 'APPROVED' && ec.comments && ec.comments.length) { %>
            <div class="mt-1 small text-muted">
              <% ec.comments.forEach(function(c) { %>
              <div><strong><%= c.author_type %>:</strong> <%= c.message %> <small>(<%= c.created_at %>)</small></div>
              <% }); %>
            </div>
            <% } %>
            <% if (!readOnly && ec.status === 'PENDING') { %>
            <div class="mt-2 d-flex flex-wrap gap-1 align-items-center">
              <button type="button" class="btn btn-gold btn-sm" data-id="<%= ec.id %>" onclick="approveExtra(this)">Approve</button>
              <button type="button" class="btn btn-outline-gold btn-sm" data-id="<%= ec.id %>" onclick="openRejectModal(this)">Reject</button>
              <button type="button" class="btn btn-outline-secondary btn-sm" data-id="<%= ec.id %>" onclick="openCommentForm(this)">Comment</button>
            </div>
            <div class="ec-comment-form mt-2 d-none" data-ec-id="<%= ec.id %>">
              <textarea class="form-control form-control-sm bg-dark text-light border-secondary mb-1" rows="2" placeholder="Your comment (optional)" style="max-width:400px"></textarea>
              <button type="button" class="btn btn-outline-gold btn-sm" onclick="submitComment(this)">Submit comment</button>
            </div>
            <% } %>
            <% } %>
          </li>
          <% }); %>
        </ul>
        <% } else { %>
        <p class="text-muted">No quotation yet.</p>
        <% } %>
      </div>
    </div>
    <div class="card card-portal mb-4">
      <div class="card-header">Payment history <span class="text-muted small fw-normal">(shared by your studio)</span></div>
      <div class="card-body">
        <% var pubPay = typeof clientPayments !== 'undefined' && clientPayments ? clientPayments : []; %>
        <% if (!pubPay.length) { %>
        <p class="text-muted mb-0">When the studio records a payment and shares it with you, it will show here with the date and amount.</p>
        <% } else { %>
        <div class="table-responsive">
          <table class="table table-dark table-sm table-borderless align-middle mb-0">
            <thead>
              <tr class="text-muted small">
                <th>Date received</th>
                <th class="text-end">Amount</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              <% pubPay.forEach(function(p) {
                   var d = p.received_date ? new Date(String(p.received_date) + 'T12:00:00') : null;
                   var dStr = d && !isNaN(d.getTime()) ? d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : (p.received_date || '—');
              %>
              <tr class="border-top border-secondary">
                <td><%= dStr %></td>
                <td class="text-end font-monospace">₹<%= (Number(p.amount) || 0).toLocaleString('en-IN') %></td>
                <td class="small text-muted"><%= p.note ? String(p.note) : '—' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
  <% if (cTabs.warranty) { %>
  <div class="tab-pane fade<%= firstVis === 'warranty' ? ' show active' : '' %>" id="tab-warranty" role="tabpanel">
    <div class="card card-portal mb-4">
      <div class="card-header serif text-warning">Warranty &amp; Guarantee</div>
      <div class="card-body">
        <% if (typeof warrantyDocs !== 'undefined' && warrantyDocs.length > 0) { %>
        <ul class="list-unstyled mb-0">
          <% warrantyDocs.forEach(function(m) { %>
          <% var wPdf = (m.type || '') === 'DOCUMENT' || (m.url || '').toLowerCase().indexOf('.pdf') !== -1; %>
          <li class="mb-2">
            <a href="<%= m.url %>" class="text-warning text-decoration-none" <% if (wPdf) { %>data-portal-pdf="1" data-portal-pdf-name="<%= String(m.file_name || 'Warranty').replace(/"/g, '&quot;') %>"<% } else { %>target="_blank" rel="noopener"<% } %>>
              <i class="bi bi-file-earmark-text me-1"></i><%= m.file_name || m.url %>
            </a>
          </li>
          <% }); %>
        </ul>
        <% } else { %>
        <p class="text-muted mb-0">No warranty/guarantee documents have been uploaded yet.</p>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
  <% if (cTabs.vastu) { %>
  <div class="tab-pane fade<%= firstVis === 'vastu' ? ' show active' : '' %>" id="tab-vastu" role="tabpanel">
    <div class="card card-portal mb-4">
      <div class="card-header serif text-warning">Vastu Documents</div>
      <div class="card-body">
        <% if (typeof vastuDocs !== 'undefined' && vastuDocs.length > 0) { %>
        <div id="vastuDocumentsList">
          <% 
          const vastuByCategory = {};
          vastuDocs.forEach(function(doc) {
            const catName = doc.vastu_category_name || 'Uncategorized';
            if (!vastuByCategory[catName]) vastuByCategory[catName] = [];
            vastuByCategory[catName].push(doc);
          });
          Object.keys(vastuByCategory).sort().forEach(function(catName) {
          %>
          <div class="mb-4">
            <h6 class="text-warning mb-2"><%= catName %></h6>
            <div class="vault-grid">
              <% vastuByCategory[catName].forEach(function(m) { %>
              <div class="vault-item rounded overflow-hidden" data-gallery-source="vastu" data-gallery-index="<%= vastuDocs.indexOf(m) %>" role="button" tabindex="0">
                <% const isVideo = (m.type || 'PHOTO') === 'VIDEO'; %>
                <% const isPdf = (m.url || '').toLowerCase().indexOf('.pdf') !== -1; %>
                <% if (isVideo) { %>
                <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center">
                  <i class="bi bi-play-circle-fill text-warning" style="font-size:2rem"></i>
                </div>
                <% } else if (isPdf) { %>
                <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center">
                  <i class="bi bi-file-earmark-pdf-fill text-danger" style="font-size:2rem"></i>
                </div>
                <% } else { %>
                <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center">
                  <img src="<%= m.url %>" alt="" loading="lazy" />
                </div>
                <% } %>
                <div class="vault-caption small text-muted text-truncate"><%= m.file_name || m.url || 'Item' %></div>
              </div>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <p class="text-muted mb-0">No Vastu documents uploaded yet.</p>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
  <% if (cTabs['other-docs']) { %>
  <%- include('../partials/other_documents_tab', { project, otherDocs: typeof otherDocs !== 'undefined' ? otherDocs : [], otherDocsMode: 'client', otherDocsTabPaneClass: firstVis === 'other-docs' ? ' show active' : '' }) %>
  <% } %>
  <% if (cTabs.messages) { %>
  <%- include('../partials/project_messages_tab', { messagesMode: 'client', project, projectMessageThreads: typeof projectMessageThreads !== 'undefined' ? projectMessageThreads : [], messagePriorities: typeof messagePriorities !== 'undefined' ? messagePriorities : [], readOnly: typeof readOnly !== 'undefined' ? readOnly : false, designerMessagingEnabled: true, messagesTabPaneClass: firstVis === 'messages' ? ' show active' : '' }) %>
  <% } %>
  <% if (cTabs.meetings) { %>
  <%- include('../partials/project_meetings_tab', { meetingsMode: 'client', project, projectMeetings: typeof projectMeetings !== 'undefined' ? projectMeetings : [], readOnly: typeof readOnly !== 'undefined' ? readOnly : false, meetingsTabPaneClass: firstVis === 'meetings' ? ' show active' : '', query: typeof query !== 'undefined' ? query : {} }) %>
