<!-- Comment history modal (for approved/superseded costs; always visible so mirror can use it) -->
<div class="modal fade" id="commentHistoryModal" tabindex="-1" aria-labelledby="commentHistoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title text-warning" id="commentHistoryModalLabel">Comment history</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="commentHistoryModalBody"></div>
    </div>
  </div>
</div>
<script>
function showCommentHistory(el) {
  var raw = el.getAttribute('data-comments');
  if (!raw) return;
  try {
    var comments = JSON.parse(decodeURIComponent(raw));
    var body = document.getElementById('commentHistoryModalBody');
    if (!body) return;
    if (!comments || comments.length === 0) { body.innerHTML = '<p class="text-muted mb-0">No comments.</p>'; }
    else {
      body.innerHTML = comments.map(function(c) {
        return '<div class="border-bottom border-secondary py-2"><strong>' + (c.author_type || '') + ':</strong> ' + (c.message || '') + ' <small class="text-muted">(' + (c.created_at || '') + ')</small></div>';
      }).join('');
    }
    if (window.bootstrap) { var m = document.getElementById('commentHistoryModal'); if (m) new bootstrap.Modal(m).show(); }
  } catch (e) {}
}
</script>

<% if (!readOnly) { %>
<script>
function projectId() { return '<%= project.id %>'; }
function approveQuotation(btn) {
  var id = btn.getAttribute('data-quotation-id');
  fetch('/portal/api/quotation/' + id + '/approve', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function() {
      // Next reload: stay on Finance tab, but default view remains Updates & Progress
      try { if (window.sessionStorage) window.sessionStorage.setItem('portalActiveTab', 'tab-finance'); } catch (e) {}
      window.location.href = window.location.pathname + window.location.search;
    });
}
function approveExtra(btn) {
  var id = btn.getAttribute('data-id');
  fetch('/portal/api/extra-cost/' + id + '/approve', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function() {
      try { if (window.sessionStorage) window.sessionStorage.setItem('portalActiveTab', 'tab-finance'); } catch (e) {}
      window.location.href = window.location.pathname + window.location.search;
    });
}

var rejectModalEl = document.getElementById('rejectModal');
var rejectReasonEl = document.getElementById('rejectReason');
var rejectErrorEl = document.getElementById('rejectError');
var rejectConfirmBtn = document.getElementById('rejectConfirmBtn');
var pendingRejectId = null;

function openRejectModal(btn) {
  pendingRejectId = btn.getAttribute('data-id');
  if (rejectReasonEl) rejectReasonEl.value = '';
  if (rejectErrorEl) { rejectErrorEl.classList.add('d-none'); rejectErrorEl.textContent = ''; }
  if (rejectModalEl && window.bootstrap) {
    var m = new bootstrap.Modal(rejectModalEl);
    m.show();
  }
}

if (rejectConfirmBtn && rejectModalEl) {
  rejectConfirmBtn.addEventListener('click', function() {
    var reason = rejectReasonEl ? rejectReasonEl.value.trim() : '';
    if (!reason) {
      if (rejectErrorEl) { rejectErrorEl.textContent = 'Please enter a reason for rejection.'; rejectErrorEl.classList.remove('d-none'); }
      return;
    }
    if (!pendingRejectId) return;
    fetch('/portal/api/extra-cost/' + pendingRejectId + '/reject', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ reason: reason })
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) { if (rejectErrorEl) { rejectErrorEl.textContent = data.error; rejectErrorEl.classList.remove('d-none'); } return; }
        if (rejectModalEl && window.bootstrap) bootstrap.Modal.getInstance(rejectModalEl).hide();
        try { if (window.sessionStorage) window.sessionStorage.setItem('portalActiveTab', 'tab-finance'); } catch (e) {}
        window.location.href = window.location.pathname + window.location.search;
      })
      .catch(function() { if (rejectErrorEl) { rejectErrorEl.textContent = 'Something went wrong.'; rejectErrorEl.classList.remove('d-none'); } });
  });
}

function openCommentForm(btn) {
  var id = btn.getAttribute('data-id');
  var forms = document.querySelectorAll('.ec-comment-form');
  forms.forEach(function(f) {
    if (f.getAttribute('data-ec-id') === id) f.classList.remove('d-none');
    else f.classList.add('d-none');
  });
}

function submitComment(btn) {
  var form = btn.closest('.ec-comment-form');
  if (!form) return;
  var id = form.getAttribute('data-ec-id');
  var ta = form.querySelector('textarea');
  var comment = ta ? ta.value.trim() : '';
  fetch('/portal/api/extra-cost/' + id + '/comment', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ comment: comment })
  })
    .then(function(r) { return r.json(); })
    .then(function() {
      try { if (window.sessionStorage) window.sessionStorage.setItem('portalActiveTab', 'tab-finance'); } catch (e) {}
      window.location.href = window.location.pathname + window.location.search;
    });
}
</script>
<% } %>
