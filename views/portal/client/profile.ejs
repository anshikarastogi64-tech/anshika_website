<% var p = typeof profile !== 'undefined' && profile ? profile : {}; %>
<% var phoneList = (typeof phones !== 'undefined' && phones && phones.length) ? phones : [{ label: 'Mobile', phone: '', id: '' }]; %>
<% var u = typeof user !== 'undefined' && user ? user : {}; %>
<% var initial = (u.full_name || u.email || '?').trim().charAt(0).toUpperCase(); %>
<style>
  .portal-profile-hero {
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.18) 0%, rgba(18, 18, 18, 0.95) 45%, rgba(18, 18, 18, 1) 100%);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    margin-bottom: 1.75rem;
    position: relative;
    overflow: hidden;
  }
  .portal-profile-hero::after {
    content: '';
    position: absolute;
    top: -40%;
    right: -10%;
    width: 45%;
    height: 140%;
    background: radial-gradient(ellipse, rgba(212, 175, 55, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .portal-profile-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: linear-gradient(145deg, #D4AF37, #8a7020);
    color: #121212;
    font-family: 'Playfair Display', serif;
    font-size: 2.25rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid rgba(248, 248, 248, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    flex-shrink: 0;
  }
  .portal-profile-section-title {
    font-family: 'Playfair Display', serif;
    color: var(--gold);
    font-size: 1.1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(212, 175, 55, 0.25);
  }
</style>

<% if (typeof query !== 'undefined' && query && query.saved) { %>
<div class="alert alert-success border border-success text-dark mb-4 py-2">Your profile was saved.</div>
<% } %>

<div class="portal-profile-hero">
  <div class="d-flex flex-wrap align-items-center gap-4 position-relative" style="z-index:1">
    <div class="portal-profile-avatar" aria-hidden="true"><%= initial %></div>
    <div class="flex-grow-1 min-w-0">
      <h1 class="serif text-warning mb-1 h3">Your profile</h1>
      <p class="text-muted small mb-0">Keep your details current so your design team can reach you and tailor your experience. Login email is shown for reference only.</p>
    </div>
    <a href="/portal/client" class="btn btn-outline-gold btn-sm flex-shrink-0">← Dashboard</a>
  </div>
</div>

<form method="post" action="/portal/client/profile" class="pb-5">
  <div class="row g-4">
    <div class="col-lg-6">
      <div class="card card-portal h-100">
        <div class="card-body">
          <h2 class="portal-profile-section-title mb-3">Identity &amp; account</h2>
          <div class="mb-3">
            <label class="form-label small text-muted mb-1" for="pf_full_name">Full name</label>
            <input type="text" id="pf_full_name" name="full_name" class="form-control form-control-sm bg-dark text-light border-secondary" required maxlength="500" value="<%= u.full_name || '' %>" autocomplete="name" />
          </div>
          <div class="mb-0">
            <label class="form-label small text-muted mb-1">Email (sign-in)</label>
            <input type="email" class="form-control form-control-sm bg-secondary bg-opacity-25 text-light border-secondary" value="<%= u.email || '' %>" readonly disabled />
            <p class="small text-muted mt-1 mb-0">To change email, contact your studio administrator.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card card-portal h-100">
        <div class="card-body">
          <h2 class="portal-profile-section-title mb-3">Personal</h2>
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label small text-muted mb-1" for="pf_dob">Date of birth</label>
              <input type="date" id="pf_dob" name="date_of_birth" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= p.date_of_birth || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted mb-1" for="pf_ann">Anniversary date</label>
              <input type="date" id="pf_ann" name="anniversary_date" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= p.anniversary_date || '' %>" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card card-portal">
        <div class="card-body">
          <h2 class="portal-profile-section-title mb-3">Work</h2>
          <p class="small text-muted mb-3">Tell us about your professional background <span class="fw-normal">(all optional)</span>.</p>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label small text-muted mb-1" for="pf_company">Company name</label>
              <input type="text" id="pf_company" name="work_company_name" class="form-control form-control-sm bg-dark text-light border-secondary" maxlength="200" placeholder="Organization you work for" value="<%= p.work_company_name || '' %>" autocomplete="organization" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted mb-1" for="pf_occ">Occupation</label>
              <input type="text" id="pf_occ" name="occupation" class="form-control form-control-sm bg-dark text-light border-secondary" maxlength="200" placeholder="e.g. Architect, physician, homemaker" value="<%= p.occupation || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-muted mb-1" for="pf_designation">Designation</label>
              <input type="text" id="pf_designation" name="job_designation" class="form-control form-control-sm bg-dark text-light border-secondary" maxlength="200" placeholder="e.g. Senior manager, Director" value="<%= p.job_designation || '' %>" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card card-portal">
        <div class="card-body">
          <h2 class="portal-profile-section-title mb-3">Address</h2>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label small text-muted mb-1" for="pf_curr">Current residence</label>
              <textarea id="pf_curr" name="current_address" class="form-control form-control-sm bg-dark text-light border-secondary" rows="4" maxlength="2000" placeholder="Street, city, PIN — where you live now"><%= p.current_address || '' %></textarea>
            </div>
          </div>
          <p class="small text-muted mt-3 mb-0">Work site address and map are managed per project under <strong>Site location &amp; contact</strong> on each project.</p>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card card-portal h-100">
        <div class="card-body">
          <h2 class="portal-profile-section-title mb-3">Phone numbers</h2>
          <p class="small text-muted mb-3">Add as many as you need (mobile, work, alternate).</p>
          <div id="phone-rows">
            <% phoneList.forEach(function(ph, i) { %>
            <div class="row g-2 mb-2 phone-row align-items-end">
              <div class="col-sm-4">
                <label class="form-label small text-muted mb-0 d-sm-none">Label</label>
                <input type="text" name="phones[<%= i %>][label]" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Label" maxlength="80" value="<%= ph.label || 'Mobile' %>" />
              </div>
              <div class="col-sm-6">
                <label class="form-label small text-muted mb-0 d-sm-none">Number</label>
                <input type="tel" name="phones[<%= i %>][number]" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="+91 …" maxlength="50" value="<%= ph.phone || '' %>" autocomplete="tel" />
              </div>
              <div class="col-sm-2">
                <button type="button" class="btn btn-outline-secondary btn-sm w-100 remove-phone" title="Remove">✕</button>
              </div>
            </div>
            <% }); %>
          </div>
          <button type="button" class="btn btn-outline-gold btn-sm mt-1" id="add-phone">+ Add number</button>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card card-portal h-100">
        <div class="card-body">
          <h2 class="portal-profile-section-title mb-3">Preferences &amp; safety</h2>
          <div class="mb-3">
            <label class="form-label small text-muted mb-1" for="pf_pref">Preferred contact</label>
            <select id="pf_pref" name="preferred_contact_method" class="form-select form-select-sm bg-dark text-light border-secondary">
              <% var pref = (p.preferred_contact_method || 'email').toLowerCase(); %>
              <option value="email" <%= pref === 'email' ? 'selected' : '' %>>Email</option>
              <option value="phone" <%= pref === 'phone' ? 'selected' : '' %>>Phone call</option>
              <option value="whatsapp" <%= pref === 'whatsapp' ? 'selected' : '' %>>WhatsApp</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small text-muted mb-1" for="pf_tz">City or timezone <span class="fw-normal">(optional)</span></label>
            <input type="text" id="pf_tz" name="timezone_or_city" class="form-control form-control-sm bg-dark text-light border-secondary" maxlength="120" placeholder="e.g. Mumbai, IST" value="<%= p.timezone_or_city || '' %>" />
          </div>
          <div class="mb-2">
            <label class="form-label small text-muted mb-1" for="pf_em_name">Emergency contact name</label>
            <input type="text" id="pf_em_name" name="emergency_contact_name" class="form-control form-control-sm bg-dark text-light border-secondary" maxlength="200" value="<%= p.emergency_contact_name || '' %>" />
          </div>
          <div class="mb-3">
            <label class="form-label small text-muted mb-1" for="pf_em_phone">Emergency contact phone</label>
            <input type="tel" id="pf_em_phone" name="emergency_contact_phone" class="form-control form-control-sm bg-dark text-light border-secondary" maxlength="50" value="<%= p.emergency_contact_phone || '' %>" />
          </div>
          <div class="mb-0">
            <label class="form-label small text-muted mb-1" for="pf_style">Design preferences <span class="fw-normal">(optional)</span></label>
            <textarea id="pf_style" name="design_style_notes" class="form-control form-control-sm bg-dark text-light border-secondary" rows="3" maxlength="2000" placeholder="Styles you love, materials to avoid, pets, accessibility…"><%= p.design_style_notes || '' %></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mt-4 pt-3 border-top border-secondary border-opacity-25">
    <p class="small text-muted mb-0">Last updated: <% if (p.updated_at) { %><%= p.updated_at %><% } else { %>—<% } %></p>
    <button type="submit" class="btn btn-gold px-4">Save profile</button>
  </div>
</form>

<script>
(function () {
  var wrap = document.getElementById('phone-rows');
  var addBtn = document.getElementById('add-phone');
  if (!wrap || !addBtn) return;
  var nextIdx = wrap.querySelectorAll('.phone-row').length;
  addBtn.addEventListener('click', function () {
    var row = document.createElement('div');
    row.className = 'row g-2 mb-2 phone-row align-items-end';
    row.innerHTML =
      '<div class="col-sm-4">' +
        '<label class="form-label small text-muted mb-0 d-sm-none">Label</label>' +
        '<input type="text" name="phones[' + nextIdx + '][label]" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Label" maxlength="80" value="Mobile" />' +
      '</div>' +
      '<div class="col-sm-6">' +
        '<label class="form-label small text-muted mb-0 d-sm-none">Number</label>' +
        '<input type="tel" name="phones[' + nextIdx + '][number]" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="+91 …" maxlength="50" />' +
      '</div>' +
      '<div class="col-sm-2">' +
        '<button type="button" class="btn btn-outline-secondary btn-sm w-100 remove-phone" title="Remove">✕</button>' +
      '</div>';
    nextIdx++;
    wrap.appendChild(row);
    row.querySelector('.remove-phone').addEventListener('click', function () { row.remove(); });
  });
  wrap.querySelectorAll('.remove-phone').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var rows = wrap.querySelectorAll('.phone-row');
      if (rows.length <= 1) {
        var inp = btn.closest('.phone-row').querySelector('input[name$="[number]"]');
        if (inp) inp.value = '';
        return;
      }
      btn.closest('.phone-row').remove();
    });
  });
})();
</script>
