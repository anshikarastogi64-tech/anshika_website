<h1 class="serif text-warning mb-4"><%= project.title %></h1>
<p class="mb-3">Client: <%= project.client_name %> | Stage: <%= LIFECYCLE_STAGES[project.current_stage] ? LIFECYCLE_STAGES[project.current_stage].name : project.current_stage %></p>

<ul class="nav nav-tabs portal-tabs mb-3" id="projectTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="tab-updates-btn" data-bs-toggle="tab" data-bs-target="#tab-updates" type="button" role="tab">Updates & Progress</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="tab-vault-btn" data-bs-toggle="tab" data-bs-target="#tab-vault" type="button" role="tab">Design Vault</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="tab-daily-btn" data-bs-toggle="tab" data-bs-target="#tab-daily" type="button" role="tab">Daily Updates</button>
  </li>
  <% if (typeof project.designer_can_see_finance === 'undefined' || project.designer_can_see_finance !== 0) { %>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="tab-finance-btn" data-bs-toggle="tab" data-bs-target="#tab-finance" type="button" role="tab">Finance</button>
  </li>
  <% } %>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="tab-vastu-btn" data-bs-toggle="tab" data-bs-target="#tab-vastu" type="button" role="tab">Vastu Documents</button>
  </li>
</ul>
<div class="tab-content" id="projectTabsContent">
  <div class="tab-pane fade show active" id="tab-updates" role="tabpanel">
    <div class="card card-portal mb-4">
      <div class="card-header">Update project</div>
      <div class="card-body">
        <form method="post" action="/portal/designer/projects/<%= project.id %>/update" class="mb-3">
          <div class="row g-2 align-items-end">
            <div class="col-auto">
              <label class="form-label small mb-0">Stage</label>
              <select name="current_stage" class="form-select form-select-sm bg-dark text-light border-secondary" style="min-width:180px">
                <% LIFECYCLE_STAGES.forEach(function(s) { %>
                <option value="<%= s.index %>" <%= project.current_stage === s.index ? 'selected' : '' %>><%= s.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-auto"><button type="submit" class="btn btn-gold btn-sm">Update stage</button></div>
          </div>
        </form>
        <form method="post" action="/portal/designer/projects/<%= project.id %>/update" class="mb-0">
          <div class="row g-2 align-items-end">
            <div class="col-auto">
              <label class="form-label small mb-0">CCTV / RTSP URL</label>
              <input type="url" name="rtsp_link" class="form-control form-control-sm bg-dark text-light border-secondary" style="min-width:280px" placeholder="https:// or rtsp://" value="<%= project.rtsp_link || '' %>" />
            </div>
            <div class="col-auto"><button type="submit" class="btn btn-outline-gold btn-sm">Save URL</button></div>
          </div>
        </form>
      </div>
    </div>
    <p class="d-flex flex-wrap gap-2">
      <% if (typeof project.designer_can_view_mirror === 'undefined' || project.designer_can_view_mirror !== 0) { %>
      <a href="/portal/mirror/<%= project.id %>" class="btn btn-gold">View as Client (Mirror)</a>
      <% } %>
      <button type="button" class="btn btn-outline-gold" onclick="window.switchToDailyUpdates && window.switchToDailyUpdates()">View Project Progress</button>
    </p>
  </div>
  <div class="tab-pane fade" id="tab-vault" role="tabpanel">
    <%- include('../partials/design_vault', { mediaByCategory: typeof mediaByCategory !== 'undefined' ? mediaByCategory : {}, byYearMonth: typeof byYearMonth !== 'undefined' ? byYearMonth : {}, vaultMediaList: typeof vaultMediaList !== 'undefined' ? vaultMediaList : [], showUpload: true, project, uploadUrl: '/portal/designer/projects/' + project.id + '/media', projectDesigns: typeof projectDesigns !== 'undefined' ? projectDesigns : [], showDailyOnly: false }) %>
  </div>
  <div class="tab-pane fade" id="tab-daily" role="tabpanel">
    <%- include('../partials/design_vault', { mediaByCategory: typeof mediaByCategory !== 'undefined' ? mediaByCategory : {}, byYearMonth: typeof byYearMonth !== 'undefined' ? byYearMonth : {}, vaultMediaList: typeof vaultMediaList !== 'undefined' ? vaultMediaList : [], showUpload: true, project, uploadUrl: '/portal/designer/projects/' + project.id + '/media', projectDesigns: typeof projectDesigns !== 'undefined' ? projectDesigns : [], dailyUpdates: typeof dailyUpdates !== 'undefined' ? dailyUpdates : [], showDailyOnly: true }) %>
  </div>
  <% if (typeof project.designer_can_see_finance === 'undefined' || project.designer_can_see_finance !== 0) { %>
  <div class="tab-pane fade" id="tab-finance" role="tabpanel">
    <div class="card card-portal mb-4">
      <div class="card-header">Quotation</div>
  <div class="card-body">
    <% if (quotation) { %>
    <p class="mb-2">Base total: ₹<%= quotation.base_total.toLocaleString() %> – Status: <strong><%= quotation.status %></strong></p>
    <% if (quotation.pdf_url) { %><p class="mb-2"><a href="<%= quotation.pdf_url %>" target="_blank" class="text-warning">View quotation PDF</a></p><% } %>
    <% if (quotation.status !== 'APPROVED') { %>
    <form method="post" action="/portal/designer/projects/<%= project.id %>/quotation/update" class="mb-3">
      <div class="row g-2 align-items-end">
        <div class="col-auto">
          <label class="form-label small mb-0">Base total (₹)</label>
          <input type="number" name="base_total" step="0.01" class="form-control form-control-sm bg-dark text-light border-secondary" style="width:120px" value="<%= quotation.base_total %>" required />
        </div>
        <div class="col-auto"><button type="submit" class="btn btn-gold btn-sm">Update quotation</button></div>
      </div>
    </form>
    <form method="post" action="/portal/designer/projects/<%= project.id %>/quotation/upload-pdf" enctype="multipart/form-data" class="mb-0">
      <input type="file" name="pdf" class="form-control form-control-sm bg-dark text-light border-secondary mb-2" accept=".pdf,application/pdf" style="max-width:280px" />
      <button type="submit" class="btn btn-outline-gold btn-sm">Upload quotation PDF</button>
    </form>
    <% } else { %><p class="text-muted small mb-0">Quotation approved. Add extra costs below for any changes.</p><% } %>
    <% } else { %>
    <p class="text-muted small mb-2">No quotation yet. Upload a PDF to create one.</p>
    <form method="post" action="/portal/designer/projects/<%= project.id %>/quotation/upload-pdf" enctype="multipart/form-data">
      <input type="file" name="pdf" class="form-control form-control-sm bg-dark text-light border-secondary mb-2" accept=".pdf,application/pdf" style="max-width:280px" />
      <button type="submit" class="btn btn-gold btn-sm">Upload quotation PDF</button>
    </form>
    <% } %>
  </div>
</div>

<div class="card card-portal mb-4">
  <div class="card-header">Additional costs (variations)</div>
  <div class="card-body">
    <p class="small text-muted mb-2">Client comments are notified to you. You can comment back or edit the cost (edit creates a new version; previous stays in history; only approved costs count toward the final invoice).</p>
    <% if (quotation) { %>
    <form method="post" action="/portal/designer/projects/<%= project.id %>/extra-cost" class="mb-3">
      <div class="row g-2 flex-wrap align-items-end">
        <div class="col-auto"><input type="text" name="description" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Description" style="min-width:180px" required /></div>
        <div class="col-auto"><input type="number" name="amount" step="0.01" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Amount (₹)" style="width:100px" required /></div>
        <div class="col-auto"><input type="text" name="comment" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Reason (optional)" style="min-width:140px" /></div>
        <div class="col-auto"><button type="submit" class="btn btn-gold btn-sm">Add extra cost</button></div>
      </div>
    </form>
    <ul class="list-unstyled small mb-0">
      <% extraCosts.forEach(function(ec) { %>
      <li class="border-bottom border-secondary py-2">
        <% if (ec.status === 'SUPERSEDED') { %>
        <span class="text-muted"><%= ec.description %> – ₹<%= ec.amount.toLocaleString() %> – <strong>Superseded</strong> (replaced by updated cost below)</span>
        <% if (ec.comments && ec.comments.length) { %>
        <span class="ms-2" title="Comment history" data-comments="<%= encodeURIComponent(JSON.stringify(ec.comments)) %>" onclick="showCommentHistory(this)" style="cursor:pointer"><i class="bi bi-chat-left-text text-warning"></i></span>
        <% } %>
        <% } else { %>
        <span><%= ec.description %> – ₹<%= ec.amount.toLocaleString() %> – <strong><%= ec.status %></strong></span>
        <% if (ec.status === 'APPROVED' && ec.comments && ec.comments.length) { %>
        <span class="ms-2" title="View comment history" data-comments="<%= encodeURIComponent(JSON.stringify(ec.comments)) %>" onclick="showCommentHistory(this)" style="cursor:pointer"><i class="bi bi-chat-left-text text-warning"></i></span>
        <% } else if (ec.status !== 'APPROVED' && ec.comments && ec.comments.length) { %>
        <div class="mt-1 text-muted">
          <% ec.comments.forEach(function(c) { %>
          <div><strong><%= c.author_type %>:</strong> <%= c.message %> <small>(<%= c.created_at %>)</small></div>
          <% }); %>
        </div>
        <% } %>
        <form method="post" action="/portal/designer/projects/<%= project.id %>/extra-cost/<%= ec.id %>/respond" class="mt-2">
          <input type="text" name="response_note" class="form-control form-control-sm bg-dark text-light border-secondary d-inline-block mb-1" placeholder="Comment back to client" style="min-width:220px" />
          <button type="submit" class="btn btn-outline-gold btn-sm">Send reply</button>
        </form>
        <form method="post" action="/portal/designer/projects/<%= project.id %>/extra-cost/<%= ec.id %>/edit" class="mt-1">
          <input type="text" name="description" class="form-control form-control-sm bg-dark text-light border-secondary d-inline-block" placeholder="New description" style="min-width:140px" value="<%= ec.description %>" required />
          <input type="number" name="amount" step="0.01" class="form-control form-control-sm bg-dark text-light border-secondary d-inline-block" style="width:90px" value="<%= ec.amount %>" required />
          <button type="submit" class="btn btn-outline-secondary btn-sm">Edit cost (new version)</button>
        </form>
        <% } %>
      </li>
      <% }); %>
    </ul>
    <% } %>
  </div>
  <div class="tab-pane fade" id="tab-vastu" role="tabpanel">
    <div class="card card-portal mb-4">
      <div class="card-header serif text-warning">Vastu Documents</div>
      <div class="card-body">
        <p class="small text-muted mb-3">Upload Vastu-related documents (images, videos, PDFs) and organize them by category. Documents require admin approval before clients can view them.</p>
        <form method="post" action="/portal/designer/projects/<%= project.id %>/media" enctype="multipart/form-data" class="mb-4">
          <div class="row g-2 align-items-end">
            <div class="col-auto">
              <label class="form-label small mb-0">Category name</label>
              <input type="text" name="vastu_category_name" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="e.g., North Direction, Entrance" style="min-width:180px" required />
            </div>
            <div class="col-auto">
              <label class="form-label small mb-0">File</label>
              <input type="file" name="file" class="form-control form-control-sm bg-dark text-light border-secondary" accept="image/*,video/*,.pdf" required />
            </div>
            <div class="col-auto">
              <input type="hidden" name="category" value="VASTU" />
              <button type="submit" class="btn btn-gold btn-sm">Upload</button>
            </div>
          </div>
        </form>
        <% if (typeof vastuDocs !== 'undefined' && vastuDocs.length > 0) { %>
        <div id="vastuDocumentsList">
          <% 
          const vastuByCategory = {};
          vastuDocs.forEach(function(doc) {
            const catName = doc.vastu_category_name || 'Uncategorized';
            if (!vastuByCategory[catName]) vastuByCategory[catName] = [];
            vastuByCategory[catName].push(doc);
          });
          Object.keys(vastuByCategory).sort().forEach(function(catName) {
          %>
          <div class="mb-4">
            <h6 class="text-warning mb-2"><%= catName %></h6>
            <div class="vault-grid">
              <% vastuByCategory[catName].forEach(function(m) { %>
              <div class="vault-item-wrapper mb-3">
                <div class="vault-item rounded overflow-hidden" data-gallery-source="vastu" data-gallery-index="<%= vastuDocs.indexOf(m) %>" role="button" tabindex="0" style="cursor:pointer">
                  <% const isVideo = (m.type || 'PHOTO') === 'VIDEO'; %>
                  <% const isPdf = (m.url || '').toLowerCase().indexOf('.pdf') !== -1; %>
                  <% if (isVideo) { %>
                  <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center">
                    <i class="bi bi-play-circle-fill text-warning" style="font-size:2rem"></i>
                  </div>
                  <% } else if (isPdf) { %>
                  <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center">
                    <i class="bi bi-file-earmark-pdf-fill text-danger" style="font-size:2rem"></i>
                  </div>
                  <% } else { %>
                  <div class="vault-thumb bg-dark d-flex align-items-center justify-content-center">
                    <img src="<%= m.url %>" alt="" loading="lazy" />
                  </div>
                  <% } %>
                  <div class="vault-caption small text-muted text-truncate"><%= m.file_name || m.url || 'Item' %></div>
                </div>
                <div class="mt-2">
                  <% if (!m.approved) { %>
                  <span class="badge bg-warning text-dark">Pending Approval</span>
                  <% } else { %>
                  <span class="badge bg-success">Approved</span>
                  <% } %>
                </div>
              </div>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <p class="text-muted mb-0">No Vastu documents uploaded yet.</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="card card-portal mb-4">
  <div class="card-header">Financials</div>
  <div class="card-body">
    <p class="serif h4 text-warning">Total: ₹<%= typeof total !== 'undefined' ? total.toLocaleString() : '0' %></p>
    <p class="small text-muted mb-0">Total = Approved quotation + approved extra costs. Client approves each item.</p>
  </div>
</div>
  </div>
</div>
  <% } %>

<script>
(function() {
  var vastuList = <%- JSON.stringify((typeof vastuDocs !== 'undefined' && vastuDocs) ? vastuDocs.map(function(m) { return { url: m.url, type: (m.type || 'PHOTO'), file_name: m.file_name || m.url, vastu_category_name: m.vastu_category_name || '' }; }) : []) %>;
  if (vastuList.length === 0) return;
  
  window.vastuList = vastuList;
  
  function openVastuGallery(index) {
    var modalEl = document.getElementById('vaultGalleryModal');
    if (!modalEl) {
      console.error('vaultGalleryModal not found. Checking if design_vault partial is loaded...');
      modalEl = document.querySelector('#vaultGalleryModal');
      if (!modalEl) {
        alert('Gallery viewer not available. Please refresh the page.');
        return;
      }
    }
    var contentEl = modalEl.querySelector('.vault-gallery-content');
    var captionEl = document.getElementById('vaultGalleryCaption');
    var sourceLabelEl = document.getElementById('vaultGallerySourceLabel');
    var counterEl = document.getElementById('vaultGalleryCounter');
    if (!contentEl) {
      console.error('vault-gallery-content not found in modal');
      return;
    }
    
    var currentList = vastuList;
    var currentSourceLabel = 'Vastu Documents';
    if (currentList.length === 0) return;
    
    var currentIdx = (index + currentList.length) % currentList.length;
    var prevBtn = modalEl.querySelector('.vault-prev');
    var nextBtn = modalEl.querySelector('.vault-next');
    
    function renderCurrent() {
      if (currentList.length === 0) return;
      var m = currentList[currentIdx];
      if (!m) return;
      var html = '';
      var fileType = (m.type || 'PHOTO').toUpperCase();
      var urlLower = (m.url || '').toLowerCase();
      
      if (fileType === 'VIDEO' || urlLower.indexOf('.mp4') !== -1 || urlLower.indexOf('.mov') !== -1 || urlLower.indexOf('.webm') !== -1) {
        html = '<video src="' + (m.url || '').replace(/"/g, '&quot;') + '" controls autoplay class="rounded" style="max-width:100%;max-height:85vh;"></video>';
      } else if (urlLower.indexOf('.pdf') !== -1) {
        var fn = (m.file_name || m.url || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
        html = '<div class="text-center"><a href="' + m.url.replace(/"/g, '&quot;') + '" target="_blank" class="btn btn-gold btn-lg">Open PDF</a><p class="text-muted small mt-3">' + fn + '</p></div>';
      } else {
        html = '<img src="' + (m.url || '').replace(/"/g, '&quot;') + '" alt="" class="rounded" style="max-width:100%;max-height:85vh;object-fit:contain;">';
      }
      contentEl.innerHTML = html;
      if (captionEl) captionEl.textContent = m.file_name || m.url || ('Item ' + (currentIdx + 1));
      if (sourceLabelEl) sourceLabelEl.textContent = currentSourceLabel;
      if (counterEl) counterEl.textContent = (currentIdx + 1) + ' / ' + currentList.length;
    }
    
    function setupNav() {
      if (prevBtn) prevBtn.onclick = function() { currentIdx = (currentIdx - 1 + currentList.length) % currentList.length; renderCurrent(); };
      if (nextBtn) nextBtn.onclick = function() { currentIdx = (currentIdx + 1) % currentList.length; renderCurrent(); };
    }
    
    renderCurrent();
    setupNav();
    
    // Use direct fallback method
    showModalFallback(modalEl);
    
    function showModalFallback(el) {
      console.log('=== showModalFallback START ===');
      var oldBackdrop = document.getElementById('vaultGalleryBackdrop');
      if (oldBackdrop) oldBackdrop.remove();
      var existingBackdrops = document.querySelectorAll('.modal-backdrop');
      existingBackdrops.forEach(function(b) { b.remove(); });
      
      if (el.parentNode !== document.body) {
        document.body.appendChild(el);
      }
      
      el.classList.add('show');
      el.style.display = 'block';
      el.style.visibility = 'visible';
      el.style.opacity = '1';
      el.style.position = 'fixed';
      el.style.top = '0';
      el.style.left = '0';
      el.style.width = '100%';
      el.style.height = '100%';
      el.style.zIndex = '1055';
      el.setAttribute('aria-hidden', 'false');
      el.setAttribute('aria-modal', 'true');
      el.setAttribute('role', 'dialog');
      
      var backdrop = document.createElement('div');
      backdrop.className = 'modal-backdrop fade show';
      backdrop.id = 'vaultGalleryBackdrop';
      backdrop.style.position = 'fixed';
      backdrop.style.top = '0';
      backdrop.style.left = '0';
      backdrop.style.width = '100%';
      backdrop.style.height = '100%';
      backdrop.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';
      backdrop.style.zIndex = '1050';
      backdrop.onclick = function() { hideModalFallback(el); };
      document.body.appendChild(backdrop);
      
      document.body.classList.add('modal-open');
      document.body.style.overflow = 'hidden';
      
      var closeBtn = el.querySelector('.btn-close');
      if (closeBtn) {
        closeBtn.onclick = function(e) {
          e.preventDefault();
          hideModalFallback(el);
        };
      }
      
      var escHandler = function(e) {
        if (e.key === 'Escape') {
          hideModalFallback(el);
          document.removeEventListener('keydown', escHandler);
        }
      };
      document.addEventListener('keydown', escHandler);
    }
    
    function hideModalFallback(el) {
      el.classList.remove('show');
      el.style.display = 'none';
      el.style.visibility = 'hidden';
      el.setAttribute('aria-hidden', 'true');
      el.removeAttribute('aria-modal');
      var backdrop = document.getElementById('vaultGalleryBackdrop');
      if (backdrop) backdrop.remove();
      var allBackdrops = document.querySelectorAll('.modal-backdrop');
      allBackdrops.forEach(function(b) { b.remove(); });
      document.body.classList.remove('modal-open');
      document.body.style.overflow = '';
    }
  }
  
  window.openVastuGallery = openVastuGallery;
  
  function attachVastuHandlers() {
    var vastuItems = document.querySelectorAll('#tab-vastu .vault-item[data-gallery-source="vastu"]');
    console.log('Found', vastuItems.length, 'Vastu items');
    vastuItems.forEach(function(item) {
      item.style.cursor = 'pointer';
      var newItem = item.cloneNode(true);
      item.parentNode.replaceChild(newItem, item);
      newItem.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var idx = parseInt(this.getAttribute('data-gallery-index') || '0', 10);
        console.log('Vastu item clicked, index:', idx);
        openVastuGallery(idx);
        return false;
      });
      var children = newItem.querySelectorAll('*');
      children.forEach(function(child) {
        child.style.pointerEvents = 'none';
      });
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachVastuHandlers);
  } else {
    attachVastuHandlers();
  }
  
  var vastuTabBtn = document.getElementById('tab-vastu-btn');
  if (vastuTabBtn) {
    vastuTabBtn.addEventListener('shown.bs.tab', function() {
      setTimeout(attachVastuHandlers, 100);
    });
  }
})();
</script>

<div class="modal fade" id="commentHistoryModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title text-warning">Comment history</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="commentHistoryModalBody"></div>
    </div>
  </div>
</div>
<script>
function showCommentHistory(el) {
  var raw = el.getAttribute('data-comments');
  if (!raw) return;
  try {
    var comments = JSON.parse(decodeURIComponent(raw));
    var body = document.getElementById('commentHistoryModalBody');
    if (!body) return;
    if (!comments || comments.length === 0) { body.innerHTML = '<p class="text-muted mb-0">No comments.</p>'; }
    else {
      body.innerHTML = comments.map(function(c) {
        return '<div class="border-bottom border-secondary py-2"><strong>' + (c.author_type || '') + ':</strong> ' + (c.message || '') + ' <small class="text-muted">(' + (c.created_at || '') + ')</small></div>';
      }).join('');
    }
    if (window.bootstrap) { var m = document.getElementById('commentHistoryModal'); if (m) new bootstrap.Modal(m).show(); }
  } catch (e) {}
}
</script>
