<h1 class="serif text-warning mb-4">My Projects</h1>
<div class="table-responsive">
  <table class="table table-dark table-striped table-bordered border-secondary">
    <thead><tr><th>Title</th><th>Client</th><th>Stage</th><th>Status</th><th>Actions</th></tr></thead>
    <tbody>
      <% projects.forEach(function(p) { %>
      <tr>
        <td><%= p.title %></td>
        <td><%= p.client_name %></td>
        <td><%= typeof lifecycleHeadline === 'function' ? lifecycleHeadline(p) : (LIFECYCLE_STAGES[p.current_stage] ? LIFECYCLE_STAGES[p.current_stage].name : p.current_stage) %></td>
        <td><%= p.status %></td>
        <td>
          <a href="/portal/designer/projects/<%= p.id %>" class="btn btn-outline-gold btn-sm">View</a>
          <a href="/portal/mirror/<%= p.id %>" class="btn btn-gold btn-sm">View as Client</a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
