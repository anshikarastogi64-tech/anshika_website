<div class="row">
  <div class="col-lg-8">
    <h1 class="h3 mb-4">Edit Testimonial</h1>
    <% if (message) { %><div class="alert alert-info"><%= message %></div><% } %>
    <form method="post" enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">Name</label>
        <input type="text" name="name" class="form-control" value="<%= (testimonial.name || '').replace(/"/g, '&quot;') %>" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Role / Title</label>
        <input type="text" name="role" class="form-control" value="<%= (testimonial.role || '').replace(/"/g, '&quot;') %>">
      </div>
      <div class="mb-3">
        <label class="form-label">Rating (1-5)</label>
        <select name="rating" class="form-select" style="max-width:100px">
          <% for (var i = 0; i <= 5; i++) { %>
          <option value="<%= i %>" <%= (testimonial.rating || 0) == i ? 'selected' : '' %>><%= i %></option>
          <% } %>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Message</label>
        <textarea name="message" rows="5" class="form-control" required><%= (testimonial.message || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') %></textarea>
      </div>
      <div class="mb-3">
        <label class="form-label">Profile Photo</label>
        <input type="file" name="image" class="form-control" accept="image/*">
        <% if (testimonial.image_path) { %><p class="mt-1 small">Current: <img src="/<%= testimonial.image_path %>" alt="" style="max-height:60px; border-radius:50%;"></p><% } %>
      </div>
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/admin/testimonials" class="btn btn-secondary">Back</a>
    </form>

    <hr class="my-4">
    <h5 class="mb-3">Media (images & videos)</h5>
    <div class="row mb-3">
      <div class="col-md-6">
        <form method="post" action="/admin/testimonials/<%= testimonial.id %>/media" enctype="multipart/form-data">
          <input type="hidden" name="media_type" value="image">
          <input type="file" name="media_files" class="form-control form-control-sm mb-2" accept="image/*" multiple>
          <button type="submit" class="btn btn-sm btn-outline-primary">Add Images</button>
        </form>
      </div>
      <div class="col-md-6">
        <form method="post" action="/admin/testimonials/<%= testimonial.id %>/media">
          <input type="hidden" name="media_type" value="video">
          <textarea name="video_urls" class="form-control form-control-sm mb-2" rows="2" placeholder="YouTube/Vimeo URLs, one per line"></textarea>
          <button type="submit" class="btn btn-sm btn-outline-primary">Add Videos</button>
        </form>
      </div>
    </div>
    <% if (testimonialMedia && testimonialMedia.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-sm">
        <thead><tr><th>Type</th><th>Preview</th><th></th></tr></thead>
        <tbody>
          <% testimonialMedia.forEach(function(m) { %>
          <tr>
            <td><span class="badge bg-secondary"><%= m.type %></span></td>
            <td>
              <% if (m.type === 'image') { %><img src="/<%= m.path %>" alt="" style="max-height:40px;"><% } %>
              <% if (m.type === 'video') { %><a href="<%= m.path %>" target="_blank">Video</a><% } %>
            </td>
            <td>
              <form method="post" action="/admin/testimonials/<%= testimonial.id %>/media/<%= m.id %>/delete" class="d-inline" onsubmit="return confirm('Remove?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-muted small">No media yet.</p>
    <% } %>
  </div>
</div>
