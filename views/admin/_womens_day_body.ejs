<div class="row">
  <div class="col-12">
    <h1 class="h3 mb-4">Women's Day Submissions</h1>
    <p class="mb-4">Photos and testimonials submitted on the Women's Day special page.</p>
    <div class="mb-3">
      <a href="/womens-day" target="_blank" class="btn btn-sm btn-outline-primary">View Public Page</a>
    </div>
  </div>
</div>
<div class="row">
  <% if (!submissions || submissions.length === 0) { %>
    <div class="col-12">
      <p class="text-muted">No submissions yet.</p>
    </div>
  <% } else {
    submissions.forEach(function(s) { %>
  <div class="col-md-6 col-lg-4 mb-4">
    <div class="card h-100">
      <% if (s.image_path) { %>
        <img src="/<%= s.image_path %>" class="card-img-top" alt="" style="height: 280px; object-fit: cover;">
      <% } else { %>
        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 280px;">
          <i class="bi bi-person display-4 text-muted"></i>
        </div>
      <% } %>
      <div class="card-body">
        <h5 class="card-title"><%= s.name %></h5>
        <% if (s.mobile) { %>
          <p class="card-text small text-muted"><%= s.mobile %></p>
        <% } %>
        <% if (s.testimonial) { %>
          <p class="card-text small">"<%= s.testimonial %>"</p>
        <% } %>
        <p class="card-text small text-muted"><%= new Date(s.created_at).toLocaleString() %></p>
        <div class="d-flex flex-wrap gap-1">
          <a href="/admin/womens-day/edit/<%= s.id %>" class="btn btn-sm btn-outline-primary">Edit</a>
          <a href="/admin/womens-day/toggle/<%= s.id %>" class="btn btn-sm btn-outline-<%= s.approved ? 'warning' : 'success' %>">
            <%= s.approved ? 'Hide' : 'Show' %>
          </a>
          <a href="/admin/womens-day/delete/<%= s.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this submission?');">Delete</a>
        </div>
      </div>
    </div>
  </div>
  <% });
  } %>
</div>
